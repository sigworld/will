---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import DemoSpeak from '../components/DemoSpeak.astro';
import DemoType from '../components/DemoType.astro';
import DemoCaption from '../components/DemoCaption.astro';
import DemoTranslate from '../components/DemoTranslate.astro';
import Privacy from '../components/Privacy.astro';
import Pricing from '../components/Pricing.astro';
---

<BaseLayout locale="en" hideHeaderUntilHero={true}>
  <Hero locale="en" />
  <div class="below-hero" data-below-hero>
    <DemoSpeak locale="en" />
    <DemoType locale="en" />
    <DemoCaption locale="en" />
    <DemoTranslate locale="en" />
    <Privacy locale="en" />
    <Pricing locale="en" />
  </div>
</BaseLayout>
