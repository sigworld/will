---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
const pricingHref = locale === 'zh' ? '/zh/pricing' : '/pricing';
---

<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>{t.pricing.title}</h2>
    </div>

    <div class="tiles" data-tile-count={t.pricing.tiles.length}>
      {t.pricing.tiles.map((tile, i) => (
        <div class={`tile ${i === 1 ? 'tile-featured' : ''}`}>
          <div class="tile-head">
            <h3>{tile.name}</h3>
            <span class="price">{tile.price}</span>
          </div>
          <p class="tile-lede">{tile.lede}</p>
          <a class={`btn ${i === 1 ? 'btn-primary' : 'btn-secondary'} tile-cta`} href={tile.href}>
            {tile.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="see-full">
      <a href={pricingHref}>{t.pricing.seeFull}</a>
    </div>
  </div>
</section>

<style>
  .tiles {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
    max-width: var(--demo-max);
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .tiles { grid-template-columns: repeat(3, 1fr); }
    .tiles[data-tile-count="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: calc(var(--demo-max) * 0.7);
    }
  }

  .tile {
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--s-5);
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    transition: border-color var(--dur-fast) var(--ease-out-quad);
  }
  .tile:hover { border-color: var(--border-strong); }
  .tile-featured {
    border-top: 2px solid var(--signal-blue);
  }

  .tile-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
  }
  .tile-head h3 {
    font-weight: var(--weight-heading);
    margin: 0;
  }
  .tile-head .price {
    font-size: 16px;
    font-weight: 600;
    color: var(--signal-blue);
    background: color-mix(in srgb, var(--signal-blue) 12%, transparent);
    padding: 5px 12px;
    border-radius: 999px;
    text-align: right;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .tile-lede {
    color: var(--text-secondary);
    font-size: var(--text-body);
    flex: 1 1 auto;
    max-width: none;
  }
  .tile-cta {
    align-self: stretch;
    text-align: center;
  }

  .see-full {
    text-align: center;
    margin-top: var(--s-5);
  }
  .see-full a {
    font-size: var(--text-body-s);
    color: var(--signal-blue);
    border-bottom: none;
  }
  .see-full a:hover { border-bottom: 1px solid currentColor; }
</style>
