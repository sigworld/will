---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
const f = t.pages.features;
const base = locale === 'zh' ? '/zh' : '';
const downloadHref = `${base}/download`;

// In zh, every "如义" mention on this page renders in brand color/weight so
// the product name stays visually anchored across long-form copy. Strings
// that already contain HTML (the body paragraphs) are processed as-is —
// "如义" never appears inside an attribute, so a blanket string replace is
// safe. The wrapper only sets color + weight, so nesting inside an existing
// <mark class="hl"> underline coexists cleanly.
const brandify = (s: string) =>
  locale === 'zh' ? s.replace(/如义/g, '<span class="brand-zh">如义</span>') : s;

// Shortcut chips. Copy strings wrap any key combo in a plain <kbd>…</kbd>
// (e.g. "<kbd>⌃⌥⇧T</kbd>" or "<kbd>Option+Shift</kbd>"). Here we expand
// each <kbd> into the same .kbd-group markup the home-page demos use,
// matching Keycaps.astro: single-glyph modifiers (⌃ ⌥ ⇧ ⌘) and literal
// keys become their own chip; named keys (Tab, Esc, Option, Shift, …)
// stay grouped as a single chip. Space and "+" act as separators inside
// the kbd source, so "Option+Shift" tokenizes cleanly.
const multiCharKeys = ['Tab', 'Enter', 'Return', 'Escape', 'Esc', 'Space', 'Cmd', 'Shift', 'Option'];
function tokenizeShortcut(input: string): string[] {
  const tokens: string[] = [];
  let i = 0;
  while (i < input.length) {
    const ch = input[i];
    if (ch === ' ' || ch === '+') { i++; continue; }
    const m = multiCharKeys.find((k) => input.startsWith(k, i));
    if (m) { tokens.push(m); i += m.length; }
    else { tokens.push(ch); i++; }
  }
  return tokens;
}
const renderShortcuts = (html: string): string =>
  html.replace(/<kbd>([^<]+)<\/kbd>/g, (_, raw: string) => {
    const tokens = tokenizeShortcut(raw);
    const chips = tokens.map((t, i) =>
      (i > 0 ? '<span class="kbd-plus" aria-hidden="true">+</span>' : '') +
      `<kbd class="kbd" data-kbd-token="${t}">${t}</kbd>`
    ).join('');
    return `<span class="kbd-group">${chips}</span>`;
  });
const decorate = (s: string) => renderShortcuts(brandify(s));

const schematics: Record<string, string> = {
  speak: `<svg viewBox="0 0 100 80" fill="none" aria-hidden="true">
    <rect x="44" y="14" width="12" height="28" rx="6" stroke="currentColor" stroke-width="1.5"/>
    <path d="M34 36 a16 16 0 0 0 32 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="50" y1="52" x2="50" y2="60" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="42" y1="60" x2="58" y2="60" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path class="wave wave-l1" d="M24 24 q-6 14 0 28" stroke="var(--signal-blue)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
    <path class="wave wave-l2" d="M14 18 q-10 20 0 40" stroke="var(--signal-blue)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
    <path class="wave wave-r1" d="M76 24 q6 14 0 28" stroke="var(--signal-blue)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
    <path class="wave wave-r2" d="M86 18 q10 20 0 40" stroke="var(--signal-blue)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
  </svg>`,
  'smart-typing': `<svg viewBox="0 0 100 80" fill="none" aria-hidden="true">
    <rect x="14" y="30" width="32" height="4" rx="1" fill="currentColor"/>
    <rect class="st-caret" x="48" y="26" width="2" height="12" fill="currentColor"/>
    <rect class="st-ghost" x="52" y="30" width="34" height="4" rx="1" fill="var(--signal-blue)"/>
    <rect x="14" y="46" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
    <path d="M18 53 L24 53 M22 50 L24 53 L22 56" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <text x="34" y="58" font-size="9" fill="currentColor" opacity="0.55" font-family="ui-sans-serif, system-ui">accept</text>
  </svg>`,
  translation: `<svg viewBox="0 0 100 80" fill="none" aria-hidden="true">
    <text x="14" y="38" font-size="22" fill="currentColor" font-weight="600" font-family="ui-sans-serif, system-ui">A</text>
    <path class="tr-arrow tr-arrow-fwd" d="M34 32 L62 32 M62 32 L56 28 M62 32 L56 36" stroke="var(--signal-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="68" y="38" font-size="20" fill="currentColor" font-weight="600" font-family="ui-sans-serif, system-ui">文</text>
    <path class="tr-arrow tr-arrow-rev" d="M62 50 L34 50 M34 50 L40 46 M34 50 L40 54" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  'caption-mode': `<svg viewBox="0 0 100 80" fill="none" aria-hidden="true">
    <rect x="10" y="14" width="80" height="46" rx="3" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="50" cy="32" r="6" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
    <rect x="20" y="46" width="60" height="8" rx="2" fill="var(--signal-blue)"/>
    <rect class="cm-text" x="24" y="49" width="52" height="2" rx="1" fill="white"/>
  </svg>`,
  context: `<svg viewBox="0 0 100 80" fill="none" aria-hidden="true">
    <rect class="ctx-layer ctx-layer-1" x="28" y="14" width="44" height="6" rx="1.5" fill="currentColor"/>
    <rect class="ctx-layer ctx-layer-2" x="22" y="24" width="56" height="6" rx="1.5" fill="currentColor"/>
    <rect class="ctx-layer ctx-layer-3" x="18" y="34" width="64" height="6" rx="1.5" fill="currentColor"/>
    <rect class="ctx-layer ctx-layer-4" x="22" y="44" width="56" height="6" rx="1.5" fill="currentColor"/>
    <rect class="ctx-layer ctx-layer-5" x="28" y="54" width="44" height="6" rx="1.5" fill="var(--signal-blue)"/>
  </svg>`,
  memory: `<svg viewBox="0 0 100 80" fill="none" aria-hidden="true">
    <ellipse cx="50" cy="18" rx="22" ry="6" stroke="currentColor" stroke-width="1.5"/>
    <path d="M28 18 L28 56 a22 6 0 0 0 44 0 L72 18" stroke="currentColor" stroke-width="1.5"/>
    <path class="mem-ring mem-ring-1" d="M28 32 a22 6 0 0 0 44 0" stroke="currentColor" stroke-width="1.5"/>
    <path class="mem-ring mem-ring-2" d="M28 46 a22 6 0 0 0 44 0" stroke="currentColor" stroke-width="1.5"/>
    <circle class="mem-dot" cx="50" cy="60" r="2" fill="var(--signal-blue)"/>
  </svg>`,
  byok: `<svg viewBox="0 0 100 80" fill="none" aria-hidden="true">
    <circle cx="30" cy="40" r="12" stroke="currentColor" stroke-width="1.5"/>
    <circle class="bk-dot" cx="30" cy="40" r="3" fill="var(--signal-blue)"/>
    <line x1="42" y1="40" x2="86" y2="40" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="68" y1="40" x2="68" y2="50" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="78" y1="40" x2="78" y2="48" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
};
---

<section class="page-hero features-hero">
  <div class="container">
    <h1 set:html={brandify(f.title)} />
    <p class="lede" set:html={brandify(f.lede)} />
  </div>
</section>

<div class="container features-shell">
  <aside class="features-toc-side" aria-label={f.tocLabel}>
    <p class="toc-label">{f.tocLabel}</p>
    <ol class="toc-list">
      {f.sections.map((s, i) => (
        <li>
          <a href={`#${s.id}`} data-toc-link>
            <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="toc-title" set:html={brandify(s.title)} />
          </a>
        </li>
      ))}
    </ol>
  </aside>
  {f.sections.map((s, i) => (
    <>
      <div
        class={`feature-diagram ${i === 0 ? 'is-first' : ''}`}
        aria-hidden="true"
        set:html={schematics[s.id] ?? ''}
      />
      <section class={`feature-section ${i === 0 ? 'is-first' : ''}`} id={s.id}>
        <h2 set:html={brandify(s.heading ?? s.title)} />
        <p class="feature-lede" set:html={brandify(s.lede)} />
        <div class="prose feature-prose">
          {s.body.map((p) => <p set:html={decorate(p)} />)}
        </div>
        <div class="feature-specs">
          {s.specs.map((spec) => <span class="chip spec-chip" set:html={decorate(spec)} />)}
        </div>
      </section>
    </>
  ))}
</div>

<section class="features-cta">
  <div class="container">
    <h2 set:html={brandify(f.ctaTitle)} />
    <a class="btn btn-primary" href={downloadHref} set:html={brandify(f.ctaButton)} />
  </div>
</section>

<style>
  .page-hero.features-hero {
    padding: var(--s-9) 0 var(--s-8);
  }
  @media (min-width: 768px) {
    .page-hero.features-hero {
      padding: var(--s-10) 0 var(--s-9);
    }
  }
  .features-hero h1 {
    font-size: clamp(32px, 4.5vw, 44px);
    line-height: var(--leading-h1);
    letter-spacing: -0.02em;
  }
  .features-hero .lede {
    margin-top: var(--s-4);
    font-size: var(--text-body-l);
  }
  .features-shell {
    display: grid;
    grid-template-columns:
      minmax(var(--s-3), 1fr)
      minmax(0, var(--prose-max))
      minmax(var(--s-3), 1fr);
    column-gap: var(--s-5);
    grid-auto-flow: dense;
    align-items: start;
  }
  .features-toc-side {
    grid-column: 3;
    grid-row: 1 / span 999;
    justify-self: start;
    width: 100%;
    max-width: 220px;
    position: sticky;
    top: 96px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }
  .feature-diagram {
    grid-column: 1;
    justify-self: end;
    width: 100%;
    max-width: 120px;
    color: var(--text-tertiary);
    padding-top: var(--s-7);
  }
  .feature-diagram.is-first { padding-top: 0; }
  .feature-diagram :global(svg) { width: 100%; height: auto; display: block; overflow: visible; }

  /* ── Speak: audio waves ripple outward */
  .feature-diagram :global(.wave) {
    opacity: 0.3;
    animation: speak-wave 1.8s ease-in-out infinite;
    transform-origin: 50px 40px;
  }
  .feature-diagram :global(.wave-l1),
  .feature-diagram :global(.wave-r1) { animation-delay: 0s; }
  .feature-diagram :global(.wave-l2),
  .feature-diagram :global(.wave-r2) { animation-delay: 0.4s; }
  @keyframes speak-wave {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.95; }
  }

  /* ── Smart Typing: caret blink + ghost suggestion fade-in */
  .feature-diagram :global(.st-caret) {
    animation: st-blink 1.1s steps(2, end) infinite;
  }
  .feature-diagram :global(.st-ghost) {
    opacity: 0;
    transform-origin: 52px 32px;
    animation: st-ghost 2.6s ease-in-out infinite;
  }
  @keyframes st-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
  @keyframes st-ghost {
    0%, 25% { opacity: 0; transform: scaleX(0.4); }
    50%, 80% { opacity: 0.5; transform: scaleX(1); }
    95%, 100% { opacity: 0; transform: scaleX(1); }
  }

  /* ── Translation: arrows flow in alternating directions */
  .feature-diagram :global(.tr-arrow) {
    stroke-dasharray: 32;
    stroke-dashoffset: 32;
    animation: tr-flow 2.6s ease-in-out infinite;
  }
  .feature-diagram :global(.tr-arrow-rev) {
    animation-delay: 1.3s;
    opacity: 0.5;
  }
  @keyframes tr-flow {
    0% { stroke-dashoffset: 32; }
    45%, 60% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -32; }
  }

  /* ── Caption Mode: text bar scales like live transcription */
  .feature-diagram :global(.cm-text) {
    transform-origin: 24px 50px;
    animation: cm-grow 2.4s ease-in-out infinite;
  }
  @keyframes cm-grow {
    0%, 10% { transform: scaleX(0); }
    55%, 90% { transform: scaleX(1); }
    100% { transform: scaleX(0); }
  }

  /* ── Context: 5 layers light up in sequence */
  .feature-diagram :global(.ctx-layer) {
    opacity: 0.2;
    animation: ctx-glow 2.4s ease-in-out infinite;
  }
  .feature-diagram :global(.ctx-layer-1) { animation-delay: 0s; }
  .feature-diagram :global(.ctx-layer-2) { animation-delay: 0.12s; }
  .feature-diagram :global(.ctx-layer-3) { animation-delay: 0.24s; }
  .feature-diagram :global(.ctx-layer-4) { animation-delay: 0.36s; }
  .feature-diagram :global(.ctx-layer-5) { animation-delay: 0.48s; opacity: 0.55; }
  @keyframes ctx-glow {
    0%, 70%, 100% { opacity: 0.2; }
    25%, 40% { opacity: 1; }
  }

  /* ── Memory: rings pulse + dot writes/reads */
  .feature-diagram :global(.mem-ring) {
    animation: mem-pulse 2.4s ease-in-out infinite;
  }
  .feature-diagram :global(.mem-ring-2) { animation-delay: 0.4s; }
  .feature-diagram :global(.mem-dot) {
    transform-origin: 50px 60px;
    animation: mem-dot 1.6s ease-in-out infinite;
  }
  @keyframes mem-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
  @keyframes mem-dot {
    0%, 100% { transform: scale(0.7); opacity: 0.5; }
    50% { transform: scale(1.3); opacity: 1; }
  }

  /* ── BYOK: keyhole dot pulses */
  .feature-diagram :global(.bk-dot) {
    transform-origin: 30px 40px;
    animation: bk-pulse 2s ease-in-out infinite;
  }
  @keyframes bk-pulse {
    0%, 100% { opacity: 0.55; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-diagram :global(svg *) {
      animation: none !important;
      opacity: 1 !important;
    }
  }
  .feature-section { grid-column: 2; min-width: 0; }
  .toc-label {
    display: none;
    font-size: var(--text-caption);
    font-weight: var(--weight-ui);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin: 0 0 var(--s-3);
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--border-subtle);
  }
  .toc-list li { margin: 0; }
  .toc-list a {
    display: flex;
    align-items: baseline;
    gap: var(--s-2);
    padding: 8px 0 8px var(--s-3);
    margin-left: -1px;
    border-left: 2px solid transparent;
    color: var(--text-tertiary);
    font-size: var(--text-body-s);
    font-weight: var(--weight-ui);
    line-height: 1.35;
    text-decoration: none;
    border-bottom: none;
    transition: color var(--dur-fast) var(--ease-out-quad),
                border-color var(--dur-fast) var(--ease-out-quad);
  }
  .toc-num {
    font-variant-numeric: tabular-nums;
    font-size: var(--text-caption);
    color: var(--text-tertiary);
    opacity: 0.7;
  }
  .toc-list a:hover {
    color: var(--text-primary);
    border-bottom: none;
  }
  .toc-list a.is-active {
    color: var(--signal-blue);
    border-left-color: var(--signal-blue);
  }
  .toc-list a.is-active .toc-num {
    color: var(--signal-blue);
    opacity: 1;
  }
  .feature-section {
    padding: var(--s-7) 0;
    border-top: 1px solid var(--border-subtle);
  }
  .feature-section.is-first {
    border-top: none;
    padding-top: 0;
  }
  .feature-section h2 {
    font-size: clamp(28px, 3.5vw, 36px);
    margin-bottom: var(--s-2);
  }
  .feature-lede {
    font-size: var(--text-body-l);
    color: var(--text-secondary);
    margin-bottom: var(--s-4);
  }
  @media (max-width: 900px) {
    .features-shell {
      grid-template-columns: minmax(0, var(--prose-max));
      justify-content: center;
      row-gap: var(--s-4);
    }
    .features-toc-side,
    .feature-section {
      grid-column: 1;
      grid-row: auto;
    }
    .features-toc-side {
      position: static;
      max-width: none;
      max-height: none;
      overflow: visible;
      padding: var(--s-4);
      background: var(--surface-soft);
      border-radius: var(--radius-md);
    }
    .feature-diagram { display: none; }
    .toc-label { display: block; }
    .toc-list { border-left: none; }
    .toc-list a {
      padding: 6px 0;
      margin-left: 0;
      border-left: none;
    }
    .toc-list a.is-active { border-left: none; }
  }
  .feature-prose p {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--text-primary);
  }
  :global(.brand-zh) {
    color: var(--signal-blue);
    font-weight: var(--weight-heading);
    font-family: var(--font-cjk);
  }
  /* On a Signal Blue background (.btn-primary), the brand color collides
     with the button fill and "如义" disappears. Fall back to the button's
     own text color; weight + CJK font still carry the brand cue. */
  :global(.btn-primary .brand-zh) {
    color: inherit;
  }
  .feature-prose :global(mark.hl) {
    background: transparent;
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--signal-blue);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    text-decoration-skip-ink: none;
  }
  /* Keycap chips inside body / specs / highlighted spans. Center the
     chip on the text's x-height (so it sits visually centered against the
     surrounding line of prose rather than dangling below the baseline)
     and drop the mark.hl underline that would otherwise cut through. */
  .feature-prose :global(.kbd-group),
  .feature-prose :global(.kbd),
  .spec-chip :global(.kbd-group),
  .spec-chip :global(.kbd) {
    vertical-align: middle;
  }
  .feature-prose :global(mark.hl) :global(.kbd-group),
  .feature-prose :global(mark.hl) :global(.kbd) {
    text-decoration: none;
  }
  .feature-specs {
    margin-top: var(--s-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .spec-chip {
    background: var(--surface-soft);
    color: var(--text-secondary);
  }
  .features-cta {
    padding: var(--s-8) 0 var(--s-7);
    border-top: 1px solid var(--border-subtle);
    text-align: center;
  }
  .features-cta h2 {
    font-size: clamp(28px, 3.5vw, 40px);
    line-height: var(--leading-h2);
    letter-spacing: -0.01em;
    margin: 0 auto var(--s-5);
    max-width: var(--prose-max);
  }
  .features-cta .btn {
    font-size: var(--text-body-l);
    padding: 14px 32px;
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
  const targets = links
    .map((link) => {
      const id = link.getAttribute('href')?.slice(1) ?? '';
      const el = id ? document.getElementById(id) : null;
      return el ? { link, el } : null;
    })
    .filter((x): x is { link: HTMLAnchorElement; el: HTMLElement } => x !== null);

  if (targets.length) {
    const setActive = (active: HTMLAnchorElement | null) => {
      for (const { link } of targets) {
        link.classList.toggle('is-active', link === active);
      }
    };

    const update = () => {
      const offset = 120;
      let current: HTMLAnchorElement | null = null;
      for (const { link, el } of targets) {
        if (el.getBoundingClientRect().top - offset <= 0) current = link;
        else break;
      }
      if (!current && window.scrollY < 200) current = targets[0].link;
      setActive(current);
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>
