---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';
import Wordmark from './Wordmark.astro';
import LangToggle from './LangToggle.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-row">
      <div class="footer-brand">
        <Wordmark locale={locale} height={32} pairZhName={locale === 'zh'} />
        <p class="formula">{t.footer.formula}</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        {t.footer.productItems.map((it) => (
          <a href={it.href}>{it.label}</a>
        ))}
      </nav>
      <div class="footer-lang">
        <LangToggle locale={locale} />
      </div>
    </div>
    <div class="footer-bottom">
      <span>{t.footer.copyright}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-soft);
    padding: var(--s-8) 0 var(--s-6);
    margin-top: var(--s-9);
  }
  /* Single horizontal row at desktop: brand on the left, the 4 product
     links inline in the middle, language toggle on the right. Collapses
     to a stacked column on narrow viewports so the nav stays tappable. */
  .footer-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-5);
  }
  @media (min-width: 768px) {
    .footer-row {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--s-6);
    }
  }
  .footer-brand .formula {
    margin-top: var(--s-2);
    font-size: var(--text-caption);
    color: var(--text-secondary);
  }
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
  }
  .footer-nav a {
    font-size: var(--text-body-s);
    color: var(--text-secondary);
    border-bottom: none;
    transition: color var(--dur-fast) var(--ease-out-quad);
  }
  .footer-nav a:hover {
    color: var(--text-primary);
    border-bottom: none;
  }
  .footer-bottom {
    margin-top: var(--s-6);
    padding-top: var(--s-5);
    border-top: 1px solid var(--border-subtle);
    font-size: var(--text-caption);
    color: var(--text-tertiary);
  }
</style>
