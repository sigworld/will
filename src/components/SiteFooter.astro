---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';
import Wordmark from './Wordmark.astro';
import LangToggle from './LangToggle.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);

const legalLinks = locale === 'zh'
  ? [
      { label: '服务条款', href: '/zh/terms' },
      { label: '隐私政策', href: '/zh/privacy-policy' },
    ]
  : [
      { label: 'Terms', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy-policy' },
    ];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-row">
      <div class="footer-brand">
        <Wordmark locale={locale} height={32} pairZhName={locale === 'zh'} />
        <p class="formula">{t.footer.formula}</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        {t.footer.productItems.map((it) => (
          <a href={it.href}>{it.label}</a>
        ))}
      </nav>
      <div class="footer-lang">
        <LangToggle locale={locale} />
      </div>
    </div>
    <div class="footer-bottom">
      <span>{t.footer.copyright}</span>
      <nav class="footer-legal" aria-label="Legal">
        {legalLinks.map((it) => (
          <a href={it.href}>{it.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    /* Top fade: page background bleeds in for the first ~160px so the
       footer's surface tint arrives gradually rather than as a hard band,
       then holds solid surface-soft through the rest. The bottom bloom
       (::after) layers over the held color. */
    background: linear-gradient(
      to bottom,
      transparent 0,
      color-mix(in srgb, var(--surface-soft) 55%, transparent) 80px,
      var(--surface-soft) 160px,
      var(--surface-soft) 100%
    );
    padding: var(--s-8) 0 var(--s-6);
    margin-top: var(--s-9);
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  /* Brand bloom at the page floor — mirrors the outer feathered range of
     the hero ribbon band so the page is bookended by the same fog gesture.
     Two layered signal-blue radials, anchored at the bottom edge and
     drifting in counter-phase. Their overlap produces a wavy bright edge:
     where they reinforce → crest, where they separate → trough. Blur is
     kept light (24px) so the motion reads through the haze. */
  .site-footer::before,
  .site-footer::after {
    content: '';
    position: absolute;
    left: -20%;
    right: -20%;
    bottom: -130px;
    height: 360px;
    pointer-events: none;
    z-index: 0;
    transform-origin: 50% 100%;
    filter: blur(16px);
    will-change: transform;
  }
  .site-footer::before {
    background: radial-gradient(
      ellipse 50% 90% at 35% 100%,
      rgba(10, 123, 255, 0.85) 0%,
      rgba(10, 123, 255, 0.45) 28%,
      rgba(10, 123, 255, 0.18) 55%,
      transparent 85%
    );
    animation: footer-bloom-wave-a 7s ease-in-out infinite;
  }
  .site-footer::after {
    background: radial-gradient(
      ellipse 48% 88% at 65% 100%,
      rgba(10, 123, 255, 0.78) 0%,
      rgba(10, 123, 255, 0.40) 28%,
      rgba(10, 123, 255, 0.14) 55%,
      transparent 85%
    );
    animation: footer-bloom-wave-b 9s ease-in-out infinite;
  }
  @keyframes footer-bloom-wave-a {
    0%, 100% { transform: translateX(-160px) translateY(14px)  scaleY(0.88) scaleX(1.10) rotate(-3deg); }
    50%      { transform: translateX(160px)  translateY(-10px) scaleY(1.10) scaleX(0.90) rotate(3deg); }
  }
  @keyframes footer-bloom-wave-b {
    0%, 100% { transform: translateX(170px)  translateY(-8px) scaleY(1.08) scaleX(0.92) rotate(3.5deg); }
    50%      { transform: translateX(-150px) translateY(16px) scaleY(0.88) scaleX(1.08) rotate(-3.5deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-footer::before,
    .site-footer::after { animation: none; }
  }
  .site-footer > .container {
    position: relative;
    z-index: 1;
  }
  /* Single horizontal row at desktop: brand on the left, the 4 product
     links inline in the middle, language toggle on the right. Collapses
     to a stacked column on narrow viewports so the nav stays tappable. */
  .footer-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-5);
  }
  @media (min-width: 768px) {
    .footer-row {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--s-6);
    }
  }
  .footer-brand .formula {
    margin-top: var(--s-2);
    font-size: var(--text-caption);
    color: var(--text-secondary);
  }
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
  }
  .footer-nav a {
    font-size: var(--text-body-s);
    color: var(--text-secondary);
    border-bottom: none;
    transition: color var(--dur-fast) var(--ease-out-quad);
  }
  .footer-nav a:hover {
    color: var(--text-primary);
    border-bottom: none;
  }
  .footer-bottom {
    margin-top: var(--s-6);
    padding-top: var(--s-5);
    border-top: 1px solid var(--border-subtle);
    font-size: var(--text-caption);
    color: var(--text-tertiary);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
  }
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-4);
  }
  .footer-legal a {
    color: var(--text-tertiary);
    border-bottom: none;
    transition: color var(--dur-fast) var(--ease-out-quad);
  }
  .footer-legal a:hover {
    color: var(--text-primary);
    border-bottom: none;
  }
</style>
