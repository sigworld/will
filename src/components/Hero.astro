---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';
import Wordmark from './Wordmark.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
const downloadHref = locale === 'zh' ? '/zh/download' : '/download';
const isZh = locale === 'zh';

// Split the headline at its natural pause so the first phrase fog-clears,
// then a longer pause, then the final phrase clears.
//   EN: "Your input, refined."   — split on ", " → ["Your input", "refined."]
//                                   the comma re-attaches to the first phrase
//                                   and a space joins the two at render
//   ZH: "如你所想 字字达意"      — split on a single space → ["如你所想", "字字达意"]
//                                   the space rejoins the two at render
const splitToken = isZh ? ' ' : ', ';
const appendToFirst = isZh ? '' : ',';
const phraseJoinSep = isZh ? ' ' : ' ';
const headlineParts = t.hero.headline.split(splitToken);
// Bars per phrase waveform. Each phrase owns its own waveform sized to
// its own text width, so the count is per-phrase, not total.
const waveformBars = 14;

// Sub line is composed of four discrete cycles, each with its own reveal
// language. Wave: a mini voice waveform plays, then the word fog-clears in
// its place (the voice-input metaphor). Type: keystrokes + candidate popup
// (the existing keyboard IME UX). Morph: the word appears in the opposing
// language (翻譯 ↔ translate) and a blur gradient swaps it for the target —
// the translation metaphor. Fog: the existing blur-clear payoff tail.
type SubCycle =
  | { kind: 'wave'; prefix: string; text: string }
  | { kind: 'type'; prefix: string; text: string; partial: string; popupRows: [string, string, string] }
  | { kind: 'morph'; prefix: string; text: string; morphFrom: string }
  | { kind: 'fog'; prefix: string; text: string };

const subCycles: SubCycle[] = isZh
  ? [
      { kind: 'wave',  prefix: '',      text: '语音' },
      { kind: 'type',  prefix: '、',    text: '键入',    partial: 'jianru', popupRows: ['键入', '渐入', '简入'] },
      { kind: 'morph', prefix: '、',    text: '翻译',    morphFrom: 'translate' },
      { kind: 'fog',   prefix: ' —— ',  text: '随心如义' },
    ]
  : [
      { kind: 'wave',  prefix: '',     text: 'Speak,' },
      { kind: 'type',  prefix: ' ',    text: 'type,',     partial: 'ty',  popupRows: ['type,', 'try,', 'tell,'] },
      { kind: 'morph', prefix: ' ',    text: 'translate', morphFrom: '翻譯' },
      { kind: 'fog',   prefix: ' — ',  text: 'at your WiLL.' },
    ];
const subWaveBars = 7;
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-title-stage" data-hero-title>
      <h1 class="hero-headline hero-headline-fog">
        {headlineParts.map((part, i) => (
          <>
            {i > 0 && phraseJoinSep}
            <span class={`phrase-cell phrase-cell-${i}`} data-phrase-idx={i}>
              <span class="phrase-waveform" aria-hidden="true">
                {Array.from({ length: waveformBars }).map((_, j) => (
                  <span style={`--bar-delay: ${(j * 47) % 600}ms;`}></span>
                ))}
              </span>
              <span class="phrase-text">
                {part}{i < headlineParts.length - 1 ? appendToFirst : ''}
              </span>
            </span>
          </>
        ))}
      </h1>
    </div>

    <div class="hero-sub-stage" data-hero-sub data-locale={locale} aria-label={t.hero.sub}>
      <p class="hero-sub hero-sub-typewriter">
        {subCycles.map((cycle, idx) => {
          const cycleAttrs = {
            'data-cycle-idx': idx,
            'data-cycle-kind': cycle.kind,
            'data-cycle-prefix': cycle.prefix,
            'data-cycle-text': cycle.text,
            ...(cycle.kind === 'type' ? { 'data-cycle-partial': cycle.partial, 'data-cycle-popup': JSON.stringify(cycle.popupRows) } : {}),
            ...(cycle.kind === 'morph' ? { 'data-cycle-from': cycle.morphFrom } : {}),
          };
          return (
            <span class={`sub-cycle sub-cycle-${cycle.kind}`} {...cycleAttrs}>
              <span class="sub-prefix" data-sub-prefix></span>
              {cycle.kind === 'wave' && (
                <span class="sub-wave-slot">
                  <span class="sub-waveform" aria-hidden="true">
                    {Array.from({ length: subWaveBars }).map((_, j) => (
                      <span style={`--bar-delay: ${(j * 53) % 480}ms;`}></span>
                    ))}
                  </span>
                  <span class="sub-wave-text">{cycle.text}</span>
                </span>
              )}
              {cycle.kind === 'type' && (
                <span class="sub-typed" data-sub-typed></span>
              )}
              {cycle.kind === 'morph' && (
                <span class="sub-morph-slot">
                  <span class="sub-morph-from" aria-hidden="true">{cycle.morphFrom}</span>
                  <span class="sub-morph-to">{cycle.text}</span>
                </span>
              )}
              {cycle.kind === 'fog' && (
                <span class="sub-fog" data-sub-fog aria-hidden="true">
                  {cycle.text.includes('WiLL') ? (
                    <>
                      {cycle.text.split('WiLL')[0]}<span class="sub-fog-brand"><Wordmark locale="en" asStatic={true} height={20} /></span>{cycle.text.split('WiLL')[1]}
                    </>
                  ) : cycle.text.includes('如义') ? (
                    <>
                      {cycle.text.split('如义')[0]}<span class="sub-fog-brand-zh">如义</span>{cycle.text.split('如义')[1]}
                    </>
                  ) : cycle.text}
                </span>
              )}
            </span>
          );
        })}
        <span class="sub-caret" data-sub-caret aria-hidden="true"></span>
      </p>
      <div class="hero-candidates" data-hero-candidates aria-hidden="true">
        <div class="cand-row" data-cand-row="0">
          <span class="cand-num">1</span>
          <span class="cand-text" data-cand-text="0"></span>
        </div>
        <div class="cand-row" data-cand-row="1">
          <span class="cand-num">2</span>
          <span class="cand-text" data-cand-text="1"></span>
        </div>
        <div class="cand-row" data-cand-row="2">
          <span class="cand-num">3</span>
          <span class="cand-text" data-cand-text="2"></span>
        </div>
      </div>
    </div>

    <div class="hero-cta">
      <a class="btn btn-primary" href={downloadHref}>{t.hero.cta}</a>
      <p class="hero-cta-sub">{t.hero.ctaSub}</p>
    </div>
    <a class="hero-arrow" href="#speak" aria-label={t.hero.seeHow}>
      <span class="hero-arrow-chevron" aria-hidden="true">
        <svg viewBox="0 0 16 10" fill="none" preserveAspectRatio="xMidYMid meet">
          <path
            d="M2 2 L8 8 L14 2"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  .hero {
    padding: var(--s-9) 0 var(--s-8);
    text-align: center;
  }
  @media (min-width: 768px) {
    .hero { padding: var(--s-10) 0 var(--s-9); }
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-5);
  }

  /* ─── Title stage: each phrase owns its own waveform sized to its own
     text width. Phrase 0 plays first, fades, and the text fog-clears in
     its place. Then phrase 1's waveform fades in, plays, fades, and its
     text fog-clears. Two discrete beats instead of one continuous bar. */
  .hero-title-stage {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .phrase-cell {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
  }

  /* Per-phrase waveform — absolutely positioned over the phrase text so it
     occupies the same width as the phrase. Phrase 1's waveform shifts
     itself right (without affecting layout) so its bars don't crowd
     "Your input," when they appear; the final assembled headline keeps
     its natural inter-phrase spacing because the cell itself has no
     extra margin. */
  .phrase-waveform {
    position: absolute;
    inset: 0;
    height: 100%;
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    pointer-events: none;
    opacity: 0;
    transition: opacity 190ms var(--ease-out-quad);
  }
  .phrase-cell-1 .phrase-waveform { left: 0.25em; right: -0.25em; }
  .phrase-cell.is-wave-on .phrase-waveform { opacity: 1; }

  .phrase-waveform span {
    display: block;
    width: 4px;
    border-radius: 2px;
    background: var(--signal-blue);
    height: 16%;
    transform-origin: center;
    animation: hero-wave 1.05s ease-in-out infinite;
    animation-delay: var(--bar-delay, 0ms);
  }
  /* Breathing effect comes from `filter: brightness()` and `transform`, NOT
     from `opacity` — keyframe-animated opacity would block the fade-out
     transition (per CSS spec, an active animation overrides transitions on
     the same property). */
  @keyframes hero-wave {
    0%, 100% { transform: scaleY(0.2); filter: brightness(0.85); }
    50%      { transform: scaleY(1.0); filter: brightness(1.05); }
  }
  /* Vary base heights so the row reads as a voice cloud, not an EQ. */
  .phrase-waveform span:nth-child(3n)    { height: 38%; }
  .phrase-waveform span:nth-child(5n+1)  { height: 58%; }
  .phrase-waveform span:nth-child(7n+2)  { height: 28%; }
  .phrase-waveform span:nth-child(11n)   { height: 70%; }
  .phrase-waveform span:nth-child(13n+1) { height: 22%; }

  .hero-headline {
    position: relative;
    z-index: 2;
    font-size: var(--text-display);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    font-weight: var(--weight-heading);
    max-width: 14ch;
    margin: 0 auto;
  }

  /* The phrase text. JS toggles `.is-text-revealed` per phrase. Opacity
     rises in 380ms (heavy blur becomes visible, but not snappy), then blur
     and translate clear leisurely over 1250ms so the text genuinely
     resolves out of fog rather than just appearing. The waveform itself
     stays brisk (190ms fade) — only the text reveal is unhurried. */
  .phrase-text {
    display: inline-block;
    opacity: 0;
    filter: blur(14px);
    transform: translateY(-6px);
    transition:
      opacity 380ms var(--ease-out-quad),
      filter 1250ms var(--ease-out-expo),
      transform 1250ms var(--ease-out-expo);
  }
  .phrase-cell.is-text-revealed .phrase-text {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  /* ─── Sub stage: typewriter line + WiLL-style candidate popup beneath. */
  .hero-sub-stage {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-sub {
    font-size: var(--text-body-l);
    color: var(--text-secondary);
    max-width: 52ch;
    margin: 0 auto;
    min-height: 1.6em;
  }
  .hero-sub-typewriter {
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
  }
  .sub-typed { white-space: pre-wrap; }

  /* ─── Sub cycles: each word is rendered as its own slot, hidden until JS
     activates it. Hiding via `display: none` (not opacity) keeps the caret
     positioned at the end of the currently active flow instead of jumping
     to the end of all reserved widths from the start. */
  .sub-cycle {
    display: none;
  }
  .sub-cycle.is-active {
    display: inline;
  }
  .sub-prefix { white-space: pre; }

  /* ─── Wave cycle ("Speak," / "语音"): a mini voice waveform plays in the
     word's slot, then crossfades into the fog-clearing text — the same
     pattern as the title's per-phrase reveal, scaled down for body type. */
  .sub-wave-slot {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
  }
  .sub-waveform {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 190ms var(--ease-out-quad);
  }
  .sub-cycle-wave.is-waving .sub-waveform { opacity: 1; }
  .sub-waveform span {
    display: block;
    width: 3px;
    border-radius: 1.5px;
    background: var(--signal-blue);
    height: 18%;
    transform-origin: center;
    animation: hero-wave 1.05s ease-in-out infinite;
    animation-delay: var(--bar-delay, 0ms);
  }
  .sub-waveform span:nth-child(3n)    { height: 44%; }
  .sub-waveform span:nth-child(5n+1)  { height: 62%; }
  .sub-waveform span:nth-child(7n+2)  { height: 32%; }
  .sub-wave-text {
    display: inline-block;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(-3px);
    transition:
      opacity 380ms var(--ease-out-quad),
      filter 900ms var(--ease-out-expo),
      transform 900ms var(--ease-out-expo);
  }
  .sub-cycle-wave.is-revealed .sub-wave-text {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  /* ─── Morph cycle ("translate" / "翻译"): vertical push-up swap. The FROM
     text (opposing language) fades into the slot, holds, then translates
     UP and out while the TO simultaneously rises in from below. Reads as
     the source word being rolled over into its translation — a concrete
     odometer-style swap, replacing the older blur crossfade. The slot
     sizes to the TO width and `overflow: hidden` clips the entering /
     exiting glyphs so they don't bleed into the line above. The TO stays
     in flow (so the inline-block's baseline = TO's baseline, which keeps
     the trailing " — " / " —— " flush against the final word); the FROM
     is absolutely positioned over it. */
  .sub-morph-slot {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
    /* Clip the entering / exiting glyphs WITHOUT using `overflow: hidden`.
       Per CSS spec, an inline-block whose overflow is non-`visible` uses
       its bottom margin edge as its baseline instead of its last text
       line's baseline — which would float "translate" above the rest of
       the subtitle line. `clip-path` clips without touching the baseline.
       The slot is sized to the TO text's width; in zh the FROM
       ("translate") is wider than the TO ("翻译") and overflows the slot
       horizontally, so we clip vertically only (top / bottom = 0) and
       leave horizontal slack (-100vw each side) so the FROM stays
       readable while the push-up swap clips it vertically. The trailing
       " —— " in cycle 3 hasn't activated yet during this beat, so the
       horizontal overflow doesn't collide with downstream text. */
    clip-path: inset(0 -100vw);
  }
  .sub-morph-from {
    position: absolute;
    top: 0;
    left: 0;
    display: inline-block;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(0);
    transition:
      opacity 360ms var(--ease-out-quad),
      transform 620ms var(--ease-out-expo);
  }
  .sub-cycle-morph.is-showing-from .sub-morph-from {
    opacity: 1;
  }
  .sub-cycle-morph.is-revealed .sub-morph-from {
    opacity: 0;
    transform: translateY(-100%);
  }
  .sub-morph-to {
    display: inline-block;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(100%);
    transition:
      opacity 360ms var(--ease-out-quad),
      transform 620ms var(--ease-out-expo);
  }
  .sub-cycle-morph.is-revealed .sub-morph-to {
    opacity: 1;
    transform: translateY(0);
  }

  /* Fog-clearing payoff tail (e.g. "at your WiLL." / "变得更好") — mirrors the
     title's `.phrase-text` reveal exactly: pre-rendered in the DOM with the
     blurred initial state so the browser has painted it long before JS adds
     `.is-revealed`. This is the only reliable way to trigger a CSS filter
     transition — dynamically appended elements have their initial state
     coalesced with the class change and skip the interpolation. */
  .sub-fog {
    display: inline-block;
    opacity: 0;
    filter: blur(14px);
    transform: translateY(-4px);
    transform-origin: left center;
    /* Brand fog: the payoff word starts as Signal Blue with a soft glow,
       then resolves to the body text color as the blur clears — the WiLL
       fog signature condensing into the punchline. */
    color: var(--signal-blue);
    text-shadow: 0 0 14px rgba(10, 123, 255, 0.55);
    transition:
      opacity 620ms var(--ease-out-quad),
      filter 1700ms var(--ease-out-expo),
      transform 1700ms var(--ease-out-expo),
      color 1900ms var(--ease-out-quad),
      text-shadow 1900ms var(--ease-out-quad);
  }
  .sub-fog.is-revealed {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
    color: var(--text-secondary);
    text-shadow: 0 0 0 rgba(10, 123, 255, 0);
  }
  /* The "WiLL" inside the payoff is the actual brand wordmark SVG — the
     left V is fixed Signal Blue, the iLL is currentColor and rides along
     with the fog's color transition (blue → text-secondary) for free. */
  .sub-fog-brand {
    display: inline-block;
    margin: 0 0.06em;
  }
  /* Override the Wordmark component's own rules so the inline glyph tracks
     the surrounding subtitle exactly:
       — `color: inherit` defeats `.wordmark { color: var(--text-primary) }`,
         which would otherwise paint the iLL near-black instead of letting
         the fog's color transition (blue → text-secondary) carry the iLL
         along via currentColor.
       — `height: 0.74em !important` beats the component's inline pixel
         height. The wordmark's glyphs (W's V and iLL caps) span ~95% of the
         viewBox; pinning that to ~0.7em puts the iLL strokes at a weight
         that optically matches Inter's body text. (The wordmark's L's and
         i are thick rectangular bars — at full cap-height they fill more
         pixels per glyph than thin Inter strokes and read visually darker
         even when hex colors match, so the SVG renders a touch smaller to
         even out optical weight.)
       — `vertical-align: -0.05em` drops the SVG just enough that the V's
         tip and L baselines sit on the text baseline rather than floating
         above it.
     `:global(.wordmark)` is required because the SVG carries Wordmark's CSS
     scope hash, not Hero's — without it the selector silently never matches. */
  .sub-fog-brand :global(.wordmark) {
    display: inline-block;
    color: inherit;
    height: 0.74em !important;
    vertical-align: -0.05em;
  }
  /* ZH counterpart: 如义 is the brand mark in zh-CN. Mirrors `.wordmark-zh-
     text` exactly — same Signal Blue, heading weight, and 0.04em letter-
     spacing — so the punchline lands on the brand identity in its native
     CJK form. `-webkit-text-fill-color` defends against the fog's color
     transition trying to repaint the glyph through any inherited cascade. */
  .sub-fog-brand-zh {
    font-family: var(--font-cjk);
    font-weight: var(--weight-heading);
    letter-spacing: 0.04em;
    color: var(--signal-blue);
    -webkit-text-fill-color: var(--signal-blue);
  }
  .sub-caret {
    display: inline-block;
    width: 2px;
    height: 1em;
    margin-left: 1px;
    background: var(--signal-blue);
    transform: translateY(2px);
    opacity: 0;
    transition: opacity 200ms var(--ease-out-quad);
  }
  .hero-sub-stage.is-ready .sub-caret {
    opacity: 1;
    animation: hero-caret-blink 1.1s steps(2, end) infinite;
  }
  .hero-sub-stage.is-done .sub-caret { display: none; }
  @keyframes hero-caret-blink { 50% { opacity: 0; } }

  /* WiLL-style candidate popup — mirrors `DemoType.astro` .candidate-popup
     styling so the hero animation reads as the same product surface. */
  .hero-candidates {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translate(-50%, -6px);
    width: min(320px, calc(100vw - var(--s-5)));
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.10);
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 180ms var(--ease-out-expo),
      transform 180ms var(--ease-out-expo);
    z-index: 3;
  }
  .hero-candidates.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  .cand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px var(--s-3);
    font-size: var(--text-body-s);
    line-height: 1.5;
    text-align: left;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-subtle);
    transition: background 140ms var(--ease-out-quad), color 140ms var(--ease-out-quad);
  }
  .cand-row:last-child { border-bottom: none; }
  .cand-row[data-cand-row="0"] { background: var(--surface-soft); }
  .cand-row.is-accepting {
    background: var(--signal-blue);
    color: var(--clean-white);
  }
  .cand-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: var(--surface-soft);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--text-tertiary);
    flex-shrink: 0;
  }
  .cand-row.is-accepting .cand-num {
    background: rgba(255, 255, 255, 0.18);
    color: var(--clean-white);
  }
  .cand-text { flex: 1; }

  /* CTA and arrow stay hidden until the sub finishes typing — keeps the
     vertical reveal order title → sub → CTA → arrow. */
  .hero-cta,
  .hero-arrow {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 500ms var(--ease-out-quad),
      transform 500ms var(--ease-out-quad);
  }
  .hero-sub-stage.is-done ~ .hero-cta {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 60ms;
  }
  /* Arrow is the LAST hero beat — it appears only after the CTA has fully
     settled (CTA: +60ms start + 500ms transition = +560ms done), with a
     breath after, so the reveal order reads cleanly as title → sub → CTA
     → arrow before the below-hero cascade begins. */
  .hero-sub-stage.is-done ~ .hero-arrow {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 820ms;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-2);
    margin-top: var(--s-3);
  }
  .hero-cta .btn { padding: 14px 28px; }
  .hero-cta-sub {
    font-size: var(--text-body-s);
    color: var(--text-tertiary);
  }
  /* Scroll hint — a single refined stroked chevron. The chevron breathes
     gently downward as a subtle directional cue. */
  .hero-arrow {
    display: inline-flex;
    margin-top: var(--s-7);
    color: var(--text-tertiary);
    text-decoration: none;
    border-bottom: none;
    transition: color var(--dur-fast) var(--ease-out-quad);
  }
  .hero-arrow:hover {
    color: var(--text-primary);
    border-bottom: none;
  }
  .hero-arrow-chevron {
    display: inline-flex;
    width: 18px;
    height: 11px;
    color: currentColor;
  }
  .hero-arrow-chevron svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }
  /* Chevron drift starts only after the link has finished its own reveal
     (sub.is-done + 820ms delay + 500ms transition = 1320ms). Driving the
     chevron — not the whole link — keeps the label visually anchored and
     reads more refined than a unified bob. */
  .hero-sub-stage.is-done ~ .hero-arrow .hero-arrow-chevron {
    animation: hero-chevron-drift 2.2s ease-in-out 1320ms infinite;
  }
  @keyframes hero-chevron-drift {
    0%, 100% { transform: translateY(-3px); opacity: 0.55; }
    50%      { transform: translateY(4px);  opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-arrow-chevron { animation: none; transform: none; }
    .phrase-waveform, .sub-waveform { display: none; }
    .phrase-text {
      opacity: 1; filter: none; transform: none; transition: none;
    }
    .sub-caret { display: none; }
    .hero-candidates { display: none; }
    .sub-cycle { display: inline; }
    .sub-wave-text, .sub-morph-to, .sub-fog {
      opacity: 1; filter: none; transform: none; transition: none;
    }
    .sub-morph-from { display: none; }
    .hero-cta,
    .hero-arrow {
      opacity: 1; transform: none; transition: none;
    }
  }
</style>

<script>
  // Orchestrate waveform → fog-reveal title → multi-modal sub cycles. The
  // sub cycles are pre-rendered as cycle slots in the DOM (see frontmatter
  // `subCycles`); each slot's `data-cycle-kind` tells this script how to
  // animate it: wave (voice waveform), type (keystrokes + candidate popup),
  // morph (blur-gradient swap from the opposing language), fog (blur-clear
  // payoff). Cycles activate sequentially via `.is-active`; the inline flow
  // grows as each one materializes so the caret naturally trails behind.
  const titleStage = document.querySelector<HTMLElement>('[data-hero-title]');
  const phraseCells = titleStage ? Array.from(titleStage.querySelectorAll<HTMLElement>('.phrase-cell')) : [];
  const subStage = document.querySelector<HTMLElement>('[data-hero-sub]');
  const cycleEls = subStage ? Array.from(subStage.querySelectorAll<HTMLElement>('[data-cycle-idx]')) : [];
  const candWin = subStage?.querySelector<HTMLElement>('[data-hero-candidates]');
  const candRows = subStage ? Array.from(subStage.querySelectorAll<HTMLElement>('[data-cand-row]')) : [];
  const candTexts = subStage ? Array.from(subStage.querySelectorAll<HTMLElement>('[data-cand-text]')) : [];

  if (titleStage && phraseCells.length >= 2 && subStage && cycleEls.length === 4 && candWin && candRows.length === 3 && candTexts.length === 3) {
    const locale = subStage.dataset.locale === 'zh' ? 'zh' : 'en';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      phraseCells.forEach((cell) => cell.classList.add('is-text-revealed'));
      cycleEls.forEach((el) => {
        const kind = el.dataset.cycleKind ?? '';
        const prefix = el.dataset.cyclePrefix ?? '';
        const text = el.dataset.cycleText ?? '';
        const prefixEl = el.querySelector<HTMLElement>('[data-sub-prefix]');
        if (prefixEl) prefixEl.textContent = prefix;
        if (kind === 'type') {
          const typedEl = el.querySelector<HTMLElement>('[data-sub-typed]');
          if (typedEl) typedEl.textContent = text;
        }
        el.classList.add('is-active', 'is-showing-from', 'is-revealed');
      });
      subStage.classList.add('is-done');
      revealBelowHero();
    } else {
      runHeroAnimation();
    }

    function revealBelowHero() {
      document.querySelector<HTMLElement>('[data-below-hero]')?.classList.add('is-revealed');
    }

    // FLIP-style leftward slide for cycles that arrive after the line has
    // already been populated. The prefix is pre-set in full (rather than
    // typed char-by-char) so the layout snapshot covers everything that
    // will be on screen after the slide — without this, the typewriter's
    // per-char width growth would cause secondary nudges mid-slide.
    async function activateWithSlide(cycleEl: HTMLElement, prefix: string) {
      const subP = subStage!.querySelector<HTMLElement>('.hero-sub');
      const firstActive = cycleEls.find((el) => el.classList.contains('is-active'));
      const prefixEl = cycleEl.querySelector<HTMLElement>('[data-sub-prefix]');
      if (prefixEl) prefixEl.textContent = prefix;
      if (!subP || !firstActive) {
        cycleEl.classList.add('is-active');
        void cycleEl.offsetWidth;
        return;
      }
      const beforeLeft = firstActive.getBoundingClientRect().left;
      cycleEl.classList.add('is-active');
      void cycleEl.offsetWidth;
      const afterLeft = firstActive.getBoundingClientRect().left;
      const deltaX = beforeLeft - afterLeft;
      if (Math.abs(deltaX) < 0.5) return;

      // ease-out-expo lands ~95% of the motion in the first half of the
      // duration, so we let the slide keep running for its full ~520ms
      // while handing control back to the caller at the halfway point.
      // The remaining glide settles in the background as the new cycle's
      // own reveal (morph from→to or fog blur-clear) begins — no dead
      // beat between slide and reveal.
      const SLIDE_MS = 520;
      const HANDOFF_MS = 260;
      subP.style.transition = 'none';
      subP.style.transform = `translateX(${deltaX}px)`;
      // Commit the pinned state before swapping in the transition so the
      // browser interpolates from translateX(deltaX) → translateX(0)
      // instead of coalescing the two writes into a single jump.
      void subP.offsetWidth;
      subP.style.transition = `transform ${SLIDE_MS}ms var(--ease-out-expo)`;
      subP.style.transform = 'translateX(0)';
      await sleep(HANDOFF_MS);
      // Don't clear the inline transform/transition here — that would yank
      // the still-settling glide mid-animation. The next activateWithSlide
      // call writes `transition: none` before its own delta, so leaving
      // translateX(0) in place is a safe no-op until then.
    }

    async function runHeroAnimation() {
      // Phase 1 — phrase 0 waveform plays, then fades while phrase 0 text
      // fog-clears in its place. Phrase 1 cell is laid out but invisible
      // (no waveform yet, text still blurred) so the headline width is
      // stable from the start. Beat durations are tuned ~40% faster than
      // the original cadence so the reveal feels brisk, not draggy.
      const waveDwellMs = locale === 'zh' ? 420 : 480;
      const phraseCell0 = phraseCells[0];
      const phraseCell1 = phraseCells[1];

      phraseCell0.classList.add('is-wave-on');
      await sleep(waveDwellMs);

      // Waveform fades (190ms) and text begins fog-clear (380ms opacity
      // + 1250ms blur clear). Drop wave-on at the same beat the text
      // reveal starts so the two crossfade.
      phraseCell0.classList.remove('is-wave-on');
      phraseCell0.classList.add('is-text-revealed');
      // Phrase 0 text is readable well before its blur fully clears — wait
      // only ~half of the 1250ms blur transition before phrase 1's waveform
      // appears, so the two phases overlap slightly instead of leaving a
      // dead pause between them. The remaining blur on phrase 0 finishes
      // resolving while phrase 1's bars vibrate.
      await sleep(600);

      // Phase 2 — phrase 1 waveform fades in, plays, then crossfades into
      // the phrase 1 text the same way.
      phraseCell1.classList.add('is-wave-on');
      await sleep(waveDwellMs);

      phraseCell1.classList.remove('is-wave-on');
      phraseCell1.classList.add('is-text-revealed');
      // Phrase 1 text is readable well before its blur fully clears — let
      // the sub-stage caret appear while phrase 1's blur is still finishing,
      // mirroring the phase 0 → phase 1 overlap so the whole reveal flows
      // without a dead gap.
      await sleep(550);

      // Phase 3 — short hand-off beat. Title's residual blur finishes
      // resolving while the sub cycle 0 (wave) starts its waveform. The
      // caret stays hidden through the wave cycle (voice input doesn't get
      // a typing cursor) and fades in at the start of the type cycle.
      await sleep(140);

      // Phase 4 — sub cycles. Each cycle animates with its own reveal
      // language; `data-cycle-kind` selects the branch.
      const subWaveDwellMs = locale === 'zh' ? 360 : 400;

      for (const cycleEl of cycleEls) {
        const kind = cycleEl.dataset.cycleKind ?? '';
        const prefix = cycleEl.dataset.cyclePrefix ?? '';
        const text = cycleEl.dataset.cycleText ?? '';
        const idx = parseInt(cycleEl.dataset.cycleIdx ?? '0', 10);

        // Morph ("translate" / "翻译") and the payoff (fog) cycles slide the
        // leading content leftward via FLIP instead of letting the inline-
        // flex line jump-recenter. The new slot is pre-laid (still invisible
        // — morph-to and fog start at opacity 0), then the whole `<p>` is
        // pinned to its old position and smoothly translated back to 0, so
        // the visible leading text glides leftward into its new centered
        // slot. Once the slide completes, the cycle's own reveal kicks in.
        if (idx >= 2) {
          await activateWithSlide(cycleEl, prefix);
        } else {
          cycleEl.classList.add('is-active');
          // Force a style commit so subsequent class-driven transitions
          // interpolate from the painted initial state instead of being
          // coalesced with the activation `display: none → inline` change.
          void cycleEl.offsetWidth;

          const prefixEl = cycleEl.querySelector<HTMLElement>('[data-sub-prefix]');
          if (prefixEl) {
            for (const ch of prefix) {
              prefixEl.textContent = (prefixEl.textContent ?? '') + ch;
              await sleep(30);
            }
          }
        }

        if (kind === 'wave') {
          cycleEl.classList.add('is-waving');
          await sleep(subWaveDwellMs);
          // Crossfade: drop the wave-on and add text-revealed in the same
          // beat so the waveform fades out as the word fog-clears in its
          // place — same hand-off pattern the title uses per phrase.
          cycleEl.classList.remove('is-waving');
          cycleEl.classList.add('is-revealed');
          // Text reads well before the 900ms blur fully clears; the residual
          // blur finishes while the next cycle's prefix is being typed.
          await sleep(540);
        } else if (kind === 'type') {
          // Caret only blinks during the type cycle — voice (wave), morph,
          // and payoff (fog) cycles have their own visual language and don't
          // read as keyboard input. Add `is-ready` on entry, drop it on exit.
          subStage!.classList.add('is-ready');
          const partial = cycleEl.dataset.cyclePartial ?? '';
          const popupRows = JSON.parse(cycleEl.dataset.cyclePopup ?? '[]') as string[];
          const typedEl = cycleEl.querySelector<HTMLElement>('[data-sub-typed]');
          if (typedEl) {
            for (const ch of partial) {
              typedEl.textContent = (typedEl.textContent ?? '') + ch;
              await sleep(30);
            }
            popupRows.forEach((row, i) => { candTexts[i].textContent = row; });
            candWin!.classList.add('is-visible');
            await sleep(420);
            candRows[0].classList.add('is-accepting');
            await sleep(150);
            typedEl.textContent = text;
            candWin!.classList.remove('is-visible');
            candRows[0].classList.remove('is-accepting');
            await sleep(180);
          }
          subStage!.classList.remove('is-ready');
        } else if (kind === 'morph') {
          // Show the FROM (e.g. 翻譯) first, hold long enough to read it as
          // a deliberate source-language form rather than a flicker, then
          // crossfade through blur into the TO (translate). Both share a
          // grid cell so the slot stays the same width across the swap.
          cycleEl.classList.add('is-showing-from');
          await sleep(460);
          cycleEl.classList.add('is-revealed');
          // Most of the 900ms blur-clear hits before we move on, matching
          // the wave-cycle hand-off cadence.
          await sleep(700);
        } else if (kind === 'fog') {
          // Payoff cycle: text is already pre-rendered in the DOM with the
          // blurred initial state — force a layout commit, then add the
          // reveal class so the filter transition interpolates. The fog
          // lingers (~1.7s blur clear + 1.9s color shift) so the brand blue
          // is on screen long enough to register before settling into the
          // body text color.
          const fogEl = cycleEl.querySelector<HTMLElement>('[data-sub-fog]');
          if (fogEl) {
            void fogEl.offsetWidth;
            fogEl.classList.add('is-revealed');
            await sleep(1500);
          }
        }
      }

      subStage!.classList.add('is-done');

      // Phase 5 — CTA + arrow fade in (driven by CSS on `.is-done`).
      // CTA at +60ms (done +560ms), arrow at +820ms (done +1320ms). Hold
      // until the arrow has fully settled before starting the below-hero
      // cascade, so the reveal order reads cleanly as title → sub → CTA
      // → arrow → sections-below rather than overlapping the cascade.
      await sleep(1500);
      revealBelowHero();
    }
  }

  function sleep(ms: number): Promise<void> {
    return new Promise((resolve) => window.setTimeout(resolve, ms));
  }
</script>
