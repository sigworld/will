---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
const downloadHref = locale === 'zh' ? '/zh/download' : '/download';
const isZh = locale === 'zh';

// Split the headline at its natural pause so the first phrase fog-clears,
// then a longer pause, then the final phrase clears.
//   EN: "Your input, refined."   — split on ", " → ["Your input", "refined."]
//                                   the comma re-attaches to the first phrase
//                                   and a space joins the two at render
//   ZH: "让你的表达 更准确"      — split on a single space → ["让你的表达", "更准确"]
//                                   the space rejoins the two at render
const splitToken = isZh ? ' ' : ', ';
const appendToFirst = isZh ? '' : ',';
const phraseJoinSep = isZh ? ' ' : ' ';
const headlineParts = t.hero.headline.split(splitToken);
// Per-phrase stagger. EN gives "refined." a long deliberate pause (1500ms);
// ZH's "更准确" follows "让你的表达" with a tighter breath since the line is
// shorter and the meaning lands faster.
const phraseStaggerMs = isZh ? 1000 : 1500;
const waveformBars = 28;
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-title-stage" data-hero-title style={`--right-fade-delay: ${phraseStaggerMs}ms;`}>
      <div class="hero-waveform" aria-hidden="true">
        {Array.from({ length: waveformBars }).map((_, i) => (
          <span style={`--bar-delay: ${(i * 47) % 600}ms;`}></span>
        ))}
      </div>
      <h1 class="hero-headline hero-headline-fog">
        {headlineParts.map((part, i) => (
          <>
            {i > 0 && phraseJoinSep}
            <span class="phrase-cell" style={`--fog-delay: ${i * phraseStaggerMs}ms`}>
              <span class="phrase-text">
                {part}{i < headlineParts.length - 1 ? appendToFirst : ''}
              </span>
            </span>
          </>
        ))}
      </h1>
    </div>

    <div class="hero-sub-stage" data-hero-sub data-locale={locale} aria-label={t.hero.sub}>
      <p class="hero-sub hero-sub-typewriter">
        <span class="sub-typed" data-sub-typed></span><span class="sub-fog" data-sub-fog aria-hidden="true"></span><span class="sub-caret" data-sub-caret aria-hidden="true"></span>
      </p>
      <div class="hero-candidates" data-hero-candidates aria-hidden="true">
        <div class="cand-row" data-cand-row="0">
          <span class="cand-num">1</span>
          <span class="cand-text" data-cand-text="0"></span>
        </div>
        <div class="cand-row" data-cand-row="1">
          <span class="cand-num">2</span>
          <span class="cand-text" data-cand-text="1"></span>
        </div>
        <div class="cand-row" data-cand-row="2">
          <span class="cand-num">3</span>
          <span class="cand-text" data-cand-text="2"></span>
        </div>
      </div>
    </div>

    <div class="hero-cta">
      <a class="btn btn-primary" href={downloadHref}>{t.hero.cta}</a>
      <p class="hero-cta-sub">{t.hero.ctaSub}</p>
    </div>
    <a class="hero-arrow" href="#speak" aria-label={t.hero.seeHow}>
      <span class="hero-arrow-chevron" aria-hidden="true">
        <svg viewBox="0 0 16 10" fill="none" preserveAspectRatio="xMidYMid meet">
          <path
            d="M2 2 L8 8 L14 2"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  .hero {
    padding: var(--s-9) 0 var(--s-8);
    text-align: center;
  }
  @media (min-width: 768px) {
    .hero { padding: var(--s-10) 0 var(--s-9); }
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-5);
  }

  /* ─── Title stage: one continuous waveform behind the whole title, with
     bars split into left/right halves that fade at different stagger times.
     The headline overlays on top — each phrase's text fog-clears on its own
     `--fog-delay`, in lockstep with its half of the waveform. */
  .hero-title-stage {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
  }
  .hero-title-stage > * { grid-area: 1 / 1; }

  .hero-waveform {
    width: min(500px, 100%);
    height: 100%;
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    pointer-events: none;
  }
  .hero-waveform span {
    display: block;
    width: 4px;
    border-radius: 2px;
    background: var(--signal-blue);
    height: 16%;
    transform-origin: center;
    animation: hero-wave 1.05s ease-in-out infinite;
    animation-delay: var(--bar-delay, 0ms);
    opacity: 1;
    transition: opacity 300ms var(--ease-out-quad);
  }
  .hero-title-stage.is-revealed .hero-waveform span { opacity: 0; }
  /* Right half of the bars (15..28) wait for the second phrase's stagger
     before fading — so the left half "recognizes" first, the right keeps
     vibrating. */
  .hero-waveform span:nth-child(n+15) {
    transition-delay: var(--right-fade-delay, 1500ms);
  }
  /* Breathing effect comes from `filter: brightness()` and `transform`, NOT
     from `opacity` — keyframe-animated opacity would block the fade-out
     transition (per CSS spec, an active animation overrides transitions on
     the same property). */
  @keyframes hero-wave {
    0%, 100% { transform: scaleY(0.2); filter: brightness(0.85); }
    50%      { transform: scaleY(1.0); filter: brightness(1.05); }
  }
  /* Vary base heights so the row reads as a voice cloud, not an EQ. */
  .hero-waveform span:nth-child(3n)    { height: 38%; }
  .hero-waveform span:nth-child(5n+1)  { height: 58%; }
  .hero-waveform span:nth-child(7n+2)  { height: 28%; }
  .hero-waveform span:nth-child(11n)   { height: 70%; }
  .hero-waveform span:nth-child(13n+1) { height: 22%; }

  .hero-headline {
    position: relative;
    z-index: 2;
    font-size: var(--text-display);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    font-weight: var(--weight-heading);
    max-width: 14ch;
    margin: 0 auto;
  }

  .phrase-cell {
    display: inline-block;
    vertical-align: baseline;
  }

  /* The phrase text. Waits 300ms after `--fog-delay` so the waveform
     underneath has fully faded before the text starts to appear. Opacity
     rises in 420ms (heavy blur becomes visible quickly), then blur and
     translate clear slowly over 1400ms so the text resolves out of fog. */
  .phrase-text {
    display: inline-block;
    opacity: 0;
    filter: blur(14px);
    transform: translateY(-6px);
    transition:
      opacity 420ms var(--ease-out-quad),
      filter 1400ms var(--ease-out-expo),
      transform 1400ms var(--ease-out-expo);
    transition-delay: calc(var(--fog-delay, 0ms) + 300ms);
  }
  .hero-title-stage.is-revealed .phrase-text {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  /* ─── Sub stage: typewriter line + WiLL-style candidate popup beneath. */
  .hero-sub-stage {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-sub {
    font-size: var(--text-body-l);
    color: var(--text-secondary);
    max-width: 52ch;
    margin: 0 auto;
    min-height: 1.6em;
  }
  .hero-sub-typewriter {
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
  }
  .sub-typed { white-space: pre-wrap; }
  /* Fog-clearing payoff tail (e.g. "way better." / "变得更好") — mirrors the
     title's `.phrase-text` reveal exactly: pre-rendered in the DOM with the
     blurred initial state so the browser has painted it long before JS adds
     `.is-revealed`. This is the only reliable way to trigger a CSS filter
     transition — dynamically appended elements have their initial state
     coalesced with the class change and skip the interpolation. */
  .sub-fog {
    display: inline-block;
    opacity: 0;
    filter: blur(14px);
    transform: translateY(-4px);
    transform-origin: left center;
    transition:
      opacity 420ms var(--ease-out-quad),
      filter 900ms var(--ease-out-expo),
      transform 900ms var(--ease-out-expo);
  }
  .sub-fog.is-revealed {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
  .sub-caret {
    display: inline-block;
    width: 2px;
    height: 1em;
    margin-left: 1px;
    background: var(--signal-blue);
    transform: translateY(2px);
    opacity: 0;
    transition: opacity 200ms var(--ease-out-quad);
  }
  .hero-sub-stage.is-ready .sub-caret {
    opacity: 1;
    animation: hero-caret-blink 1.1s steps(2, end) infinite;
  }
  .hero-sub-stage.is-done .sub-caret { display: none; }
  @keyframes hero-caret-blink { 50% { opacity: 0; } }

  /* WiLL-style candidate popup — mirrors `DemoType.astro` .candidate-popup
     styling so the hero animation reads as the same product surface. */
  .hero-candidates {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translate(-50%, -6px);
    width: min(320px, calc(100vw - var(--s-5)));
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.10);
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 180ms var(--ease-out-expo),
      transform 180ms var(--ease-out-expo);
    z-index: 3;
  }
  .hero-candidates.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  .cand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px var(--s-3);
    font-size: var(--text-body-s);
    line-height: 1.5;
    text-align: left;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-subtle);
    transition: background 140ms var(--ease-out-quad), color 140ms var(--ease-out-quad);
  }
  .cand-row:last-child { border-bottom: none; }
  .cand-row[data-cand-row="0"] { background: var(--surface-soft); }
  .cand-row.is-accepting {
    background: var(--signal-blue);
    color: var(--clean-white);
  }
  .cand-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: var(--surface-soft);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--text-tertiary);
    flex-shrink: 0;
  }
  .cand-row.is-accepting .cand-num {
    background: rgba(255, 255, 255, 0.18);
    color: var(--clean-white);
  }
  .cand-text { flex: 1; }

  /* CTA and arrow stay hidden until the sub finishes typing — keeps the
     vertical reveal order title → sub → CTA → arrow. */
  .hero-cta,
  .hero-arrow {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 500ms var(--ease-out-quad),
      transform 500ms var(--ease-out-quad);
  }
  .hero-sub-stage.is-done ~ .hero-cta {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 60ms;
  }
  /* Arrow is the LAST hero beat — it appears only after the CTA has fully
     settled (CTA: +60ms start + 500ms transition = +560ms done), with a
     breath after, so the reveal order reads cleanly as title → sub → CTA
     → arrow before the below-hero cascade begins. */
  .hero-sub-stage.is-done ~ .hero-arrow {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 820ms;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-2);
    margin-top: var(--s-3);
  }
  .hero-cta .btn { padding: 14px 28px; }
  .hero-cta-sub {
    font-size: var(--text-body-s);
    color: var(--text-tertiary);
  }
  /* Scroll hint — a single refined stroked chevron. The chevron breathes
     gently downward as a subtle directional cue. */
  .hero-arrow {
    display: inline-flex;
    margin-top: var(--s-7);
    color: var(--text-tertiary);
    text-decoration: none;
    border-bottom: none;
    transition: color var(--dur-fast) var(--ease-out-quad);
  }
  .hero-arrow:hover {
    color: var(--text-primary);
    border-bottom: none;
  }
  .hero-arrow-chevron {
    display: inline-flex;
    width: 18px;
    height: 11px;
    color: currentColor;
  }
  .hero-arrow-chevron svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }
  /* Chevron drift starts only after the link has finished its own reveal
     (sub.is-done + 820ms delay + 500ms transition = 1320ms). Driving the
     chevron — not the whole link — keeps the label visually anchored and
     reads more refined than a unified bob. */
  .hero-sub-stage.is-done ~ .hero-arrow .hero-arrow-chevron {
    animation: hero-chevron-drift 2.2s ease-in-out 1320ms infinite;
  }
  @keyframes hero-chevron-drift {
    0%, 100% { transform: translateY(-3px); opacity: 0.55; }
    50%      { transform: translateY(4px);  opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-arrow-chevron { animation: none; transform: none; }
    .hero-waveform { display: none; }
    .phrase-text {
      opacity: 1; filter: none; transform: none; transition: none;
    }
    .sub-caret { display: none; }
    .hero-candidates { display: none; }
    .sub-fog { opacity: 1; filter: none; transform: none; transition: none; }
    .hero-cta,
    .hero-arrow {
      opacity: 1; transform: none; transition: none;
    }
  }
</style>

<script>
  type Cycle = {
    /** Typed verbatim before the partial; NOT replaced on accept (used for
     *  connectors like 、 or " —— " that the user "types" as keystrokes
     *  rather than picks from the candidate window). */
    prefix?: string;
    /** Pinyin / Latin chars typed; REPLACED with `accept` when the top
     *  candidate is taken. Ignored when `fog: true`. */
    partial: string;
    /** Hanzi / English completion that replaces the partial. */
    accept: string;
    /** Three display strings in the candidate window. Ignored when `fog: true`. */
    popupRows: string[];
    /** When true, skip the candidate-popup flow: type the prefix, then
     *  fog-reveal `accept` inline (blur-clearing like the title). Used on the
     *  final cycle for a more fluent payoff. */
    fog?: boolean;
  };

  // Orchestrate waveform → fog-reveal title → typewriter sub with locale-
  // appropriate candidate cycles. EN cycles type partial English letters and
  // accept English completions; ZH cycles type pinyin and accept hanzi
  // (with the leading punctuation 、 / — baked into the accept text).
  const titleStage = document.querySelector<HTMLElement>('[data-hero-title]');
  const subStage = document.querySelector<HTMLElement>('[data-hero-sub]');
  const subTyped = subStage?.querySelector<HTMLElement>('[data-sub-typed]');
  const subFog = subStage?.querySelector<HTMLElement>('[data-sub-fog]');
  const candWin = subStage?.querySelector<HTMLElement>('[data-hero-candidates]');
  const candRows = subStage ? Array.from(subStage.querySelectorAll<HTMLElement>('[data-cand-row]')) : [];
  const candTexts = subStage ? Array.from(subStage.querySelectorAll<HTMLElement>('[data-cand-text]')) : [];

  if (titleStage && subStage && subTyped && subFog && candWin && candRows.length === 3 && candTexts.length === 3) {
    const finalSub = subStage.getAttribute('aria-label') ?? '';
    const locale = subStage.dataset.locale === 'zh' ? 'zh' : 'en';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      titleStage.classList.add('is-revealed');
      subTyped.textContent = finalSub;
      subStage.classList.add('is-done');
      revealBelowHero();
    } else {
      runHeroAnimation();
    }

    function revealBelowHero() {
      document.querySelector<HTMLElement>('[data-below-hero]')?.classList.add('is-revealed');
    }

    async function runHeroAnimation() {
      // Phase 1 — voice waveform.
      await sleep(800);

      // Phase 2 — title fog-clears phrase-by-phrase. Per-phrase stagger is
      // locale-specific (EN 1500ms, ZH 1000ms). The waveform under each
      // phrase fades over 300ms, then the text begins its reveal (420ms
      // opacity + 1400ms blur clear). Final phrase fully sharp at
      // stagger + 300 + 1400 = stagger + 1700 ms.
      const phraseStaggerMs = locale === 'zh' ? 1000 : 1500;
      titleStage.classList.add('is-revealed');
      await sleep(phraseStaggerMs + 1700);

      // Phase 3 — caret appears (hidden until the title is fully readable),
      // holds for a beat, then typing begins.
      subStage.classList.add('is-ready');
      await sleep(280);

      // Phase 4 — typewriter sub with locale-specific cycles.
      const cycles = parseCycles(finalSub, locale);

      for (const cycle of cycles) {
        // Type the prefix first — these chars stay (they're the punctuation
        // separators the user types directly, not picked from a candidate).
        const prefix = cycle.prefix ?? '';
        for (const ch of prefix) {
          subTyped.textContent = (subTyped.textContent ?? '') + ch;
          await sleep(30);
        }

        if (cycle.fog) {
          // Payoff cycle: skip the candidate popup. Fill the pre-rendered
          // `.sub-fog` span and add `.is-revealed` — same mechanism the title
          // uses on `.phrase-text`. Pre-rendering is essential: the browser
          // must have painted the blurred initial state before the class
          // change, otherwise the transition is coalesced away.
          subFog.textContent = cycle.accept;
          // Force the browser to commit the new layout (text width) before the
          // class change, so the transition runs from the fully-laid-out
          // blurred state rather than from "empty span".
          void subFog.offsetWidth;
          subFog.classList.add('is-revealed');
          // Wait for the slower filter transition (900ms) to mostly clear.
          await sleep(900);
          continue;
        }

        // Then type the partial — these chars WILL be replaced on accept.
        for (let i = 0; i < cycle.partial.length; i++) {
          subTyped.textContent = (subTyped.textContent ?? '') + cycle.partial[i];
          await sleep(30);
        }
        const beforeAcceptTyped = subTyped.textContent ?? '';

        cycle.popupRows.forEach((text, i) => { candTexts[i].textContent = text; });
        candWin.classList.add('is-visible');
        await sleep(420);

        candRows[0].classList.add('is-accepting');
        await sleep(150);

        const trunkLen = beforeAcceptTyped.length - cycle.partial.length;
        const trunk = beforeAcceptTyped.slice(0, trunkLen);
        subTyped.textContent = trunk + cycle.accept;

        candWin.classList.remove('is-visible');
        candRows[0].classList.remove('is-accepting');
        await sleep(180);
      }

      subStage.classList.add('is-done');

      // Phase 5 — CTA + arrow fade in (driven by CSS on `.is-done`).
      // CTA at +60ms (done +560ms), arrow at +820ms (done +1320ms). Hold
      // until the arrow has fully settled before starting the below-hero
      // cascade, so the reveal order reads cleanly as title → sub → CTA
      // → arrow → sections-below rather than overlapping the cascade.
      await sleep(1500);
      revealBelowHero();
    }
  }

  function sleep(ms: number): Promise<void> {
    return new Promise((resolve) => window.setTimeout(resolve, ms));
  }

  function parseCycles(text: string, locale: 'en' | 'zh'): Cycle[] {
    // Each cycle's accept-text fully replaces its partial when accepted, so
    // concatenating the accepts must equal the final sub copy. If they don't
    // match (e.g. the i18n copy drifts), fall back to typing in one shot.
    const cycles: Cycle[] = locale === 'zh'
      ? [
          // ZH: pinyin → hanzi. Connectors 、 / —— are typed as `prefix` —
          // they appear as keystrokes the user makes directly, the way a
          // real Chinese IME treats the 、 key. The pinyin partial is what
          // gets replaced when a hanzi candidate is accepted.
          { prefix: '',       partial: 'yuyin',   accept: '语音',  popupRows: ['语音',   '余音',   '雨音'] },
          { prefix: '、',     partial: 'jianru',  accept: '键入',  popupRows: ['键入',   '渐入',   '简入'] },
          { prefix: '、',     partial: 'fanyi',   accept: '翻译',  popupRows: ['翻译',   '反义',   '翻意'] },
          // Payoff: type the connector, then fog-reveal 变得更好 inline —
          // mirrors the title's blur-clear so the sub lands in one fluid beat
          // instead of another candidate-popup interruption.
          { prefix: ' —— ',   partial: '', accept: '变得更好', popupRows: [], fog: true },
        ]
      : [
          { prefix: '',       partial: 'Sp',  accept: 'Speak,',       popupRows: ['Speak,',      'Speech.',     'Special?'] },
          { prefix: ' ',      partial: 'ty',  accept: 'type,',        popupRows: ['type,',       'try,',        'tell,'] },
          { prefix: ' ',      partial: 'tra', accept: 'translate',    popupRows: ['translate',   'transcribe',  'transmit'] },
          { prefix: ' — ',    partial: '',    accept: 'way better.',  popupRows: [], fog: true },
        ];
    // Each cycle contributes `prefix + accept` to the final sub copy. The
    // partial is REPLACED by accept, but the prefix stays as typed.
    const assembled = cycles.map((c) => (c.prefix ?? '') + c.accept).join('');
    if (assembled !== text) {
      return [{ partial: text, accept: text, popupRows: ['', '', ''] }];
    }
    return cycles;
  }
</script>
