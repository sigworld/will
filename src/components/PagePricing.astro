---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
const p = t.pages.pricing;
const base = locale === 'zh' ? '/zh' : '';
const downloadHref = `${base}/download`;
---

<section class="page-hero">
  <div class="container">
    <h1>{p.title}</h1>
    <p class="lede">{p.lede}</p>
  </div>
</section>

<section class="pricing-grid-section">
  <div class="container">
    <div class="tiles" data-tile-count={p.tiles.length}>
      {p.tiles.map((tile) => (
        <article class={`tile tile-${tile.id}`} id={tile.id}>
          <header class="tile-header">
            <div class="tile-header-row">
              <h2>{tile.name}</h2>
              <span class="price">{tile.price}</span>
            </div>
            <p class="tile-lede">{tile.lede}</p>
          </header>
          <div class="tile-body">
            <ul class="tile-list">
              {tile.included.map((it) => <li>{it}</li>)}
            </ul>
          </div>
          <div class="tile-cta-wrap">
            {tile.ctaNote && <span class="cta-note">{tile.ctaNote}</span>}
            <a class={`btn ${tile.id === 'pro' ? 'btn-primary' : 'btn-secondary'} tile-cta`} href={tile.href === '/download' || tile.href === '/zh/download' ? downloadHref : tile.href}>{tile.cta}</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="faq-section">
  <div class="container">
    <h2 class="faq-title">{p.faqTitle}</h2>
    <div class="faq-list">
      {p.faq.map((item, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="pricing-cta">
  <div class="container">
    <h2>{p.ctaTitle}</h2>
    <a class="btn btn-primary" href={downloadHref}>{p.ctaButton}</a>
  </div>
</section>

<style>
  .pricing-grid-section {
    padding: var(--s-6) 0 var(--s-8);
  }
  .tiles {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
  }
  @media (min-width: 768px) {
    .tiles {
      grid-template-columns: repeat(3, 1fr);
    }
    .tiles[data-tile-count="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: 720px;
      margin: 0 auto;
    }
    .tiles[data-tile-count="1"] {
      grid-template-columns: minmax(0, 1fr);
      max-width: 480px;
      margin: 0 auto;
    }
  }
  .tile {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    padding: var(--s-5);
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    transition: border-color var(--dur-fast) var(--ease-out-quad);
  }
  .tile:hover {
    border-color: var(--border-strong);
  }
  .tile-pro {
    border-color: var(--signal-blue);
  }
  .tile-header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
    margin-bottom: var(--s-3);
  }
  .tile-header h2 {
    font-size: var(--text-h3);
    margin: 0;
  }
  .price {
    font-size: 18px;
    font-weight: 600;
    color: var(--signal-blue);
    background: color-mix(in srgb, var(--signal-blue) 12%, transparent);
    padding: 5px 12px;
    border-radius: 999px;
    text-align: right;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .tile-lede {
    font-size: var(--text-body);
    color: var(--text-primary);
  }
  .tile-body {
    flex: 1;
  }
  .tile-list {
    display: flex;
    flex-direction: column;
    gap: var(--s-1);
  }
  .tile-list li {
    font-size: var(--text-body-s);
    color: var(--text-primary);
    padding-left: var(--s-3);
    position: relative;
    line-height: var(--leading-body);
  }
  .tile-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal-blue);
    opacity: 0.6;
  }
  .tile-cta-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .tile-cta {
    align-self: stretch;
  }
  .cta-note {
    position: absolute;
    top: -14px;
    right: -14px;
    background: var(--bg-primary);
    color: var(--signal-blue);
    font-size: 11.5px;
    font-weight: 600;
    line-height: 1;
    padding: 7px 13px;
    border-radius: 999px;
    white-space: nowrap;
    z-index: 1;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    border: 1.5px solid color-mix(in srgb, var(--signal-blue) 40%, transparent);
    box-shadow: 0 4px 10px rgba(10, 123, 255, 0.18);
    transform: rotate(8deg);
    transform-origin: center;
  }
  .faq-section {
    padding: var(--s-8) 0;
    background: var(--surface-soft);
  }
  .faq-title {
    margin-bottom: var(--s-5);
    text-align: center;
  }
  .faq-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-2);
    max-width: var(--prose-max);
    margin: 0 auto;
    align-items: start;
  }
  @media (min-width: 900px) {
    .faq-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--s-4);
      max-width: 1040px;
    }
  }
  .faq-item {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    padding: var(--s-3) var(--s-4);
    transition: border-color var(--dur-fast) var(--ease-out-quad);
  }
  .faq-item[open] {
    border-color: var(--border-strong);
  }
  .faq-item summary {
    cursor: pointer;
    font-weight: var(--weight-ui);
    font-size: var(--text-body);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s-3);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    color: var(--text-tertiary);
    font-weight: var(--weight-body);
    font-size: 20px;
    line-height: 1;
    transition: transform var(--dur-fast) var(--ease-out-quad);
  }
  .faq-item[open] summary::after {
    content: '−';
  }
  .faq-item p {
    margin-top: var(--s-3);
    color: var(--text-secondary);
    line-height: var(--leading-body);
    font-size: var(--text-body-s);
  }
  .pricing-cta {
    padding: var(--s-8) 0 var(--s-4);
    text-align: center;
  }
  .pricing-cta h2 {
    font-size: var(--text-h3);
    margin-bottom: var(--s-3);
  }
</style>
