---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
const p = t.pages.privacy;

/** Split "lead (note)" → { lead, note }. Lets the table render parenthetical
 *  qualifiers (e.g. "✓ (fallback)") as a star marker with a hover tooltip,
 *  keeping the cell visually compact. */
function splitNote(text: string): { lead: string; note: string | null } {
  const m = text.match(/^(.*?)\s?\(([^)]+)\)\s*$/);
  return m ? { lead: m[1].trim(), note: m[2].trim() } : { lead: text, note: null };
}
---

<section class="page-hero">
  <div class="container">
    <h1>{p.title}</h1>
    <p class="lede">{p.lede}</p>
  </div>
</section>

<div class="container privacy-body">
  <section class="priv-block" id="stays">
    <h2>{p.stays.title}</h2>
    <ul class="priv-list">
      {p.stays.items.map((it) => <li>{it}</li>)}
    </ul>
    <p class="priv-aside">{p.stays.note}</p>
  </section>

  <section class="priv-block" id="leaves">
    <h2>{p.leaves.title}</h2>
    <div class="prose">
      {p.leaves.items.map((it) => (
        <div class="named-item">
          <h3>{it.name}</h3>
          <p>{it.body}</p>
        </div>
      ))}
    </div>
    <figure class="diagram" aria-label={p.leaves.diagramCaption}>
      <div class="diagram-row">
        {p.leaves.diagramSteps.map((step, i) => (
          <>
            <div class="diagram-box">{step}</div>
            {i < p.leaves.diagramSteps.length - 1 && <div class="diagram-arrow" aria-hidden="true">→</div>}
          </>
        ))}
      </div>
      <figcaption>{p.leaves.diagramCaption}</figcaption>
    </figure>
  </section>

  <section class="priv-block" id="paths">
    <h2>{p.paths.title}</h2>
    <div class="paths-grid">
      {p.paths.items.map((it) => (
        <div class="path-card">
          <h3>{it.name}</h3>
          <p>{it.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="priv-block" id="never">
    <h2>{p.never.title}</h2>
    <ul class="priv-list never-list">
      {p.never.items.map((it) => <li>{it}</li>)}
    </ul>
  </section>

  <section class="priv-block priv-table-block" id="reference">
    <h2>{p.table.title}</h2>
    <p class="priv-table-lede">{p.table.lede}</p>
    <div class="priv-table-scroll" role="region" aria-label={p.table.title} tabindex="0">
      <table class="priv-table priv-table--main">
        <colgroup>
          <col class="col-feature" />
          <col class="col-mark" />
          <col class="col-mark" />
          <col class="col-data" />
          <col class="col-switch" />
        </colgroup>
        <thead>
          <tr>
            <th scope="col">{p.table.headers.feature}</th>
            <th scope="col">{p.table.headers.local}</th>
            <th scope="col">{p.table.headers.cloud}</th>
            <th scope="col">{p.table.headers.transmitted}</th>
            <th scope="col">{p.table.headers.killSwitch}</th>
          </tr>
        </thead>
        <tbody>
          {p.table.rows.map((r) => {
            const lc = splitNote(r.local);
            const cc = splitNote(r.cloud);
            const tc = splitNote(r.transmitted);
            const kc = splitNote(r.killSwitch);
            return (
              <tr>
                <th scope="row">{r.feature}</th>
                <td>{lc.lead}{lc.note && <span class="cell-note" title={lc.note} tabindex="0" aria-label={lc.note}>*</span>}</td>
                <td>{cc.lead}{cc.note && <span class="cell-note" title={cc.note} tabindex="0" aria-label={cc.note}>*</span>}</td>
                <td>{tc.lead}{tc.note && <span class="cell-note" title={tc.note} tabindex="0" aria-label={tc.note}>*</span>}</td>
                <td>{kc.lead}{kc.note && <span class="cell-note" title={kc.note} tabindex="0" aria-label={kc.note}>*</span>}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <h3 class="priv-subheading">{p.table.permissionsTitle}</h3>
    <div class="priv-table-scroll" role="region" aria-label={p.table.permissionsTitle} tabindex="0">
      <table class="priv-table priv-table--narrow">
        <thead>
          <tr>
            <th scope="col">{p.table.permissionsHeaders.permission}</th>
            <th scope="col">{p.table.permissionsHeaders.purpose}</th>
            <th scope="col">{p.table.permissionsHeaders.requiredFor}</th>
          </tr>
        </thead>
        <tbody>
          {p.table.permissions.map((row) => (
            <tr>
              <th scope="row">{row.permission}</th>
              <td>{row.purpose}</td>
              <td>{row.requiredFor}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <p class="priv-footnote">{p.footerNote}</p>
</div>

<style>
  .privacy-body {
    padding-top: var(--s-6);
    padding-bottom: var(--s-8);
  }
  .priv-block {
    padding: var(--s-6) 0;
    border-top: 1px solid var(--border-subtle);
  }
  .priv-block > h2,
  .priv-block > .prose,
  .priv-list,
  .priv-aside,
  .priv-footnote {
    max-width: var(--prose-max);
    margin-left: auto;
    margin-right: auto;
  }
  .priv-block:first-child {
    border-top: none;
    padding-top: var(--s-2);
  }
  .priv-block h2 {
    margin-bottom: var(--s-4);
  }
  .priv-list {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .priv-list li {
    font-size: var(--text-body);
    color: var(--text-primary);
    padding-left: var(--s-4);
    position: relative;
    line-height: var(--leading-body);
  }
  .priv-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal-blue);
    opacity: 0.6;
  }
  .priv-aside {
    margin-top: var(--s-4);
    padding: var(--s-3) var(--s-4);
    background: var(--surface-soft);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: var(--text-body-s);
    line-height: var(--leading-body);
  }
  .named-item {
    margin-bottom: var(--s-4);
  }
  .named-item h3 {
    font-size: var(--text-body-l);
    font-weight: var(--weight-heading);
    margin-bottom: var(--s-1);
  }
  .named-item p {
    color: var(--text-secondary);
    line-height: var(--leading-body);
  }
  .diagram {
    margin: var(--s-5) 0 0;
    padding: var(--s-4);
    background: var(--surface-soft);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .diagram-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--s-2);
    margin-bottom: var(--s-3);
  }
  .diagram-box {
    padding: 8px 14px;
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-size: var(--text-body-s);
    font-weight: var(--weight-ui);
    color: var(--text-primary);
  }
  .diagram-arrow {
    color: var(--text-tertiary);
    font-size: 18px;
  }
  .diagram figcaption {
    font-size: var(--text-caption);
    color: var(--text-tertiary);
  }
  .paths-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-3);
  }
  @media (min-width: 768px) {
    .paths-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .path-card {
    padding: var(--s-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
  }
  .path-card h3 {
    font-size: var(--text-body-l);
    font-weight: var(--weight-heading);
    margin-bottom: var(--s-2);
  }
  .path-card p {
    color: var(--text-secondary);
    font-size: var(--text-body-s);
    line-height: var(--leading-body);
  }
  .never-list li::before {
    background: var(--onyx);
    opacity: 0.5;
  }
  .priv-footnote {
    margin-top: var(--s-6);
    padding-top: var(--s-4);
    border-top: 1px solid var(--border-subtle);
    font-size: var(--text-body-s);
    color: var(--text-tertiary);
    font-style: italic;
  }
  .priv-table-block > h2,
  .priv-table-lede,
  .priv-subheading {
    max-width: var(--prose-max);
    margin-left: auto;
    margin-right: auto;
  }
  .priv-table-lede {
    color: var(--text-secondary);
    line-height: var(--leading-body);
    margin-bottom: var(--s-4);
  }
  .priv-subheading {
    margin-top: var(--s-6);
    margin-bottom: var(--s-3);
    font-size: var(--text-body-l);
    font-weight: var(--weight-heading);
  }
  .priv-table-scroll {
    overflow-x: auto;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
  }
  .priv-table-scroll:focus-visible {
    outline: 2px solid var(--signal-blue);
    outline-offset: 2px;
  }
  .priv-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-body-s);
    line-height: var(--leading-body);
  }
  .priv-table--main {
    min-width: 880px;
    table-layout: fixed;
  }
  .priv-table--main .col-feature { width: 22%; }
  .priv-table--main .col-mark    { width: 17%; }
  .priv-table--main .col-data    { width: 22%; }
  .priv-table--main .col-switch  { width: 22%; }
  .priv-table--narrow {
    min-width: 560px;
  }
  .priv-table th,
  .priv-table td {
    padding: var(--s-3) var(--s-4);
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--border-subtle);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .priv-table--main thead th:nth-child(2),
  .priv-table--main thead th:nth-child(3),
  .priv-table--main tbody td:nth-child(2),
  .priv-table--main tbody td:nth-child(3) {
    text-align: center;
  }
  .priv-table--main tbody td:nth-child(2),
  .priv-table--main tbody td:nth-child(3) {
    white-space: nowrap;
  }
  .priv-table thead th {
    background: var(--surface-soft);
    font-weight: var(--weight-heading);
    color: var(--text-primary);
    position: sticky;
    top: 0;
    z-index: 1;
    white-space: normal;
    line-height: 1.3;
  }
  .priv-table tbody th {
    font-weight: var(--weight-ui);
    color: var(--text-primary);
  }
  .priv-table--main tbody th {
    white-space: pre-line;
  }
  .cell-note {
    display: inline-block;
    margin-left: 3px;
    color: var(--signal-blue);
    font-weight: var(--weight-heading);
    cursor: help;
    line-height: 1;
    vertical-align: super;
    font-size: 0.85em;
    text-decoration: none;
  }
  .cell-note:focus-visible {
    outline: 2px solid var(--signal-blue);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .priv-table tbody td {
    color: var(--text-secondary);
  }
  .priv-table tbody tr:last-child th,
  .priv-table tbody tr:last-child td {
    border-bottom: none;
  }
  .priv-table tbody tr:hover th,
  .priv-table tbody tr:hover td {
    background: var(--surface-soft);
  }
</style>
