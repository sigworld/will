---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
const p = t.pages.privacy;

const toc = [
  { id: 'stays', title: p.stays.title },
  { id: 'leaves', title: p.leaves.title },
  { id: 'paths', title: p.paths.title },
  { id: 'never', title: p.never.title },
];

/** Split "lead (note)" → { lead, note }. Lets the table render parenthetical
 *  qualifiers (e.g. "✓ (fallback)") as a star marker with a hover tooltip,
 *  keeping the cell visually compact. */
function splitNote(text: string): { lead: string; note: string | null } {
  const m = text.match(/^(.*?)\s?\(([^)]+)\)\s*$/);
  return m ? { lead: m[1].trim(), note: m[2].trim() } : { lead: text, note: null };
}
---

<section class="page-hero">
  <div class="container">
    <h1>{p.title}</h1>
    <p class="lede">{p.lede}</p>
  </div>
</section>

<div class="container privacy-shell">
  <aside class="privacy-toc-side" aria-label={t.pages.features.tocLabel}>
    <p class="toc-label">{t.pages.features.tocLabel}</p>
    <ol class="toc-list">
      {toc.map((s, i) => (
        <li>
          <a href={`#${s.id}`} data-priv-toc>
            <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="toc-title">{s.title}</span>
          </a>
        </li>
      ))}
    </ol>
  </aside>

  <section class="priv-block is-first" id="stays">
    <h2>{p.stays.title}</h2>
    <ul class="priv-list">
      {p.stays.items.map((it) => <li>{it}</li>)}
    </ul>
  </section>

  <section class="priv-block" id="leaves">
    <h2>{p.leaves.title}</h2>
    <figure class="diagram" aria-label={p.leaves.diagramCaption}>
      <div class="diagram-row diagram-row-roundtrip">
        <div class="diagram-box">{p.leaves.diagramSteps[0]}</div>
        <div class="diagram-arrow diagram-arrow-bi" aria-hidden="true">
          <span class="diagram-arrow-line">→</span>
          <span class="diagram-arrow-line">←</span>
        </div>
        <div class="diagram-box">{p.leaves.diagramSteps[1]}</div>
      </div>
      <figcaption>{p.leaves.diagramCaption}</figcaption>
    </figure>
    <div class="prose">
      {p.leaves.items.map((it) => (
        <div class="named-item">
          <h3>{it.name}</h3>
          <p>{it.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="priv-block" id="paths">
    <h2>{p.paths.title}</h2>
    <div class="paths-grid">
      {p.paths.items.map((it) => (
        <div class="path-card">
          <h3>{it.name}</h3>
          <p>{it.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="priv-block" id="never">
    <h2>{p.never.title}</h2>
    <ul class="priv-list never-list">
      {p.never.items.map((it) => <li>{it}</li>)}
    </ul>
  </section>
</div>

<div class="container priv-reference-wrap">
  <section class="priv-table-block" id="reference">
    <h2>{p.table.title}</h2>
    <div class="priv-table-scroll" role="region" aria-label={p.table.title} tabindex="0">
      <table class="priv-table priv-table--main">
        <colgroup>
          <col class="col-feature" />
          <col class="col-mark" />
          <col class="col-mark" />
          <col class="col-data" />
          <col class="col-switch" />
        </colgroup>
        <thead>
          <tr>
            <th scope="col">{p.table.headers.feature}</th>
            <th scope="col">{p.table.headers.local}</th>
            <th scope="col">{p.table.headers.cloud}</th>
            <th scope="col">{p.table.headers.transmitted}</th>
            <th scope="col">{p.table.headers.killSwitch}</th>
          </tr>
        </thead>
        <tbody>
          {p.table.rows.map((r) => {
            const lc = splitNote(r.local);
            const cc = splitNote(r.cloud);
            const tc = splitNote(r.transmitted);
            const kc = splitNote(r.killSwitch);
            return (
              <tr>
                <th scope="row">{r.feature}</th>
                <td>{lc.lead}{lc.note && <span class="cell-note" title={lc.note} tabindex="0" aria-label={lc.note}>*</span>}</td>
                <td>{cc.lead}{cc.note && <span class="cell-note" title={cc.note} tabindex="0" aria-label={cc.note}>*</span>}</td>
                <td>{tc.lead}{tc.note && <span class="cell-note" title={tc.note} tabindex="0" aria-label={tc.note}>*</span>}</td>
                <td>{kc.lead}{kc.note && <span class="cell-note" title={kc.note} tabindex="0" aria-label={kc.note}>*</span>}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <h3 class="priv-subheading">{p.table.permissionsTitle}</h3>
    <div class="priv-table-scroll" role="region" aria-label={p.table.permissionsTitle} tabindex="0">
      <table class="priv-table priv-table--narrow">
        <thead>
          <tr>
            <th scope="col">{p.table.permissionsHeaders.permission}</th>
            <th scope="col">{p.table.permissionsHeaders.purpose}</th>
            <th scope="col">{p.table.permissionsHeaders.requiredFor}</th>
          </tr>
        </thead>
        <tbody>
          {p.table.permissions.map((row) => (
            <tr>
              <th scope="row">{row.permission}</th>
              <td>{row.purpose}</td>
              <td>{row.requiredFor}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <p class="priv-footnote">{p.footerNote}</p>
</div>

<style>
  /* Mirrors .features-shell: 1120px container, sticky TOC sidebar on the
     right, content column at --prose-max on the left. The reference block
     opts into a wider span so the data-flow table can breathe. */
  .privacy-shell {
    display: grid;
    grid-template-columns:
      minmax(var(--s-3), 1fr)
      minmax(0, var(--prose-max))
      minmax(var(--s-3), 1fr);
    column-gap: var(--s-5);
    grid-auto-flow: dense;
    align-items: start;
    padding-top: var(--s-6);
    padding-bottom: var(--s-4);
  }
  /* Reference tables sit outside the TOC-indexed shell and use the
     full container width. */
  .priv-reference-wrap {
    padding-top: var(--s-4);
    padding-bottom: var(--s-6);
  }
  .priv-reference-wrap .priv-table-block {
    padding-top: var(--s-6);
    border-top: 1px solid var(--border-subtle);
    scroll-margin-top: 96px;
  }
  .priv-reference-wrap .priv-table-block h2 {
    margin-bottom: var(--s-4);
  }
  .privacy-toc-side {
    grid-column: 3;
    grid-row: 1 / span 999;
    justify-self: start;
    width: 100%;
    max-width: 220px;
    position: sticky;
    top: 96px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }
  .privacy-toc-side .toc-label {
    font-size: var(--text-caption);
    font-weight: var(--weight-ui);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin: 0 0 var(--s-3);
  }
  .privacy-toc-side .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--border-subtle);
  }
  .privacy-toc-side .toc-list li { margin: 0; }
  .privacy-toc-side .toc-list a {
    display: flex;
    align-items: baseline;
    gap: var(--s-2);
    padding: 8px 0 8px var(--s-3);
    margin-left: -1px;
    border-left: 2px solid transparent;
    color: var(--text-tertiary);
    font-size: var(--text-body-s);
    font-weight: var(--weight-ui);
    line-height: 1.35;
    text-decoration: none;
    border-bottom: none;
    transition: color var(--dur-fast) var(--ease-out-quad),
                border-color var(--dur-fast) var(--ease-out-quad);
  }
  .privacy-toc-side .toc-list a:hover {
    color: var(--text-primary);
    border-bottom: none;
  }
  .privacy-toc-side .toc-list a.is-active {
    color: var(--signal-blue);
    border-left-color: var(--signal-blue);
  }
  .privacy-toc-side .toc-num {
    font-variant-numeric: tabular-nums;
    font-size: var(--text-caption);
    color: var(--text-tertiary);
    opacity: 0.7;
  }
  .privacy-toc-side .toc-list a.is-active .toc-num {
    color: var(--signal-blue);
    opacity: 1;
  }
  /* All blocks span the diagram-gutter + content column: features puts
     animated diagrams in the left gutter — privacy has none, so the
     content itself uses that real estate. */
  .priv-block {
    grid-column: 1 / span 2;
    min-width: 0;
    padding: var(--s-6) 0;
    border-top: 1px solid var(--border-subtle);
    scroll-margin-top: 96px;
  }
  .priv-block.is-first {
    border-top: none;
    padding-top: var(--s-2);
  }
  .priv-block h2 {
    margin-bottom: var(--s-4);
  }
  /* Two-column bullet layout — at wider widths short bullets sit
     side-by-side instead of leaving the right half empty next to
     the TOC sidebar. */
  .priv-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-2) var(--s-6);
  }
  @media (min-width: 768px) {
    .priv-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .priv-list li {
    font-size: var(--text-body);
    color: var(--text-primary);
    padding-left: var(--s-4);
    position: relative;
    line-height: var(--leading-body);
  }
  .priv-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal-blue);
    opacity: 0.6;
  }
  /* The "leaves" section: diagram banner spans the full width above,
     then three named-items sit side-by-side as cards (matching the
     paths section below so the page reads as one design language). */
  #leaves .prose {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-3);
    max-width: none;
  }
  @media (min-width: 768px) {
    #leaves .prose {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-4);
    }
  }
  .named-item {
    padding: var(--s-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
  }
  .named-item h3 {
    font-size: var(--text-body-l);
    font-weight: var(--weight-heading);
    margin-bottom: var(--s-2);
  }
  .named-item p {
    color: var(--text-secondary);
    font-size: var(--text-body-s);
    line-height: var(--leading-body);
  }
  /* Diagram sits above the cards as a one-line flow banner. Stretches
     edge-to-edge so the long content area carries a clear visual
     instead of trailing empty space below the cards. */
  .diagram {
    margin: 0 0 var(--s-5);
    padding: var(--s-4) var(--s-5);
    background: var(--surface-soft);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .diagram-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    margin-bottom: var(--s-2);
  }
  .diagram-box {
    flex: 1 1 0;
    min-width: 110px;
    padding: 10px 14px;
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-size: var(--text-body-s);
    font-weight: var(--weight-ui);
    color: var(--text-primary);
  }
  .diagram-arrow {
    flex: 0 0 auto;
    color: var(--signal-blue);
    font-size: 20px;
    opacity: 0.7;
  }
  .diagram-arrow-bi {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.05;
    gap: 2px;
  }
  .diagram-arrow-bi .diagram-arrow-line {
    font-size: 22px;
    font-weight: var(--weight-ui);
  }
  .diagram figcaption {
    font-size: var(--text-caption);
    color: var(--text-tertiary);
  }
  .paths-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-3);
  }
  @media (min-width: 768px) {
    .paths-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .path-card {
    padding: var(--s-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
  }
  .path-card h3 {
    font-size: var(--text-body-l);
    font-weight: var(--weight-heading);
    margin-bottom: var(--s-2);
  }
  .path-card p {
    color: var(--text-secondary);
    font-size: var(--text-body-s);
    line-height: var(--leading-body);
  }
  .never-list li::before {
    background: var(--onyx);
    opacity: 0.5;
  }
  .priv-footnote {
    margin-top: var(--s-6);
    padding-top: var(--s-4);
    border-top: 1px solid var(--border-subtle);
    font-size: var(--text-body-s);
    color: var(--text-tertiary);
    font-style: italic;
  }
  .priv-subheading {
    margin-top: var(--s-6);
    margin-bottom: var(--s-3);
    font-size: var(--text-body-l);
    font-weight: var(--weight-heading);
  }
  .priv-table-scroll {
    overflow-x: auto;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
  }
  .priv-table-scroll:focus-visible {
    outline: 2px solid var(--signal-blue);
    outline-offset: 2px;
  }
  .priv-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-body-s);
    line-height: var(--leading-body);
  }
  .priv-table--main {
    min-width: 880px;
    table-layout: fixed;
  }
  .priv-table--main .col-feature { width: 22%; }
  .priv-table--main .col-mark    { width: 17%; }
  .priv-table--main .col-data    { width: 22%; }
  .priv-table--main .col-switch  { width: 22%; }
  .priv-table--narrow {
    min-width: 560px;
  }
  .priv-table th,
  .priv-table td {
    padding: var(--s-3) var(--s-4);
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--border-subtle);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .priv-table--main thead th:nth-child(2),
  .priv-table--main thead th:nth-child(3),
  .priv-table--main tbody td:nth-child(2),
  .priv-table--main tbody td:nth-child(3) {
    text-align: center;
  }
  .priv-table--main tbody td:nth-child(2),
  .priv-table--main tbody td:nth-child(3) {
    white-space: nowrap;
  }
  .priv-table thead th {
    background: var(--surface-soft);
    font-weight: var(--weight-heading);
    color: var(--text-primary);
    position: sticky;
    top: 0;
    z-index: 1;
    white-space: normal;
    line-height: 1.3;
  }
  .priv-table tbody th {
    font-weight: var(--weight-ui);
    color: var(--text-primary);
  }
  .priv-table--main tbody th {
    white-space: pre-line;
  }
  .cell-note {
    display: inline-block;
    margin-left: 3px;
    color: var(--signal-blue);
    font-weight: var(--weight-heading);
    cursor: help;
    line-height: 1;
    vertical-align: super;
    font-size: 0.85em;
    text-decoration: none;
  }
  .cell-note:focus-visible {
    outline: 2px solid var(--signal-blue);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .priv-table tbody td {
    color: var(--text-secondary);
  }
  .priv-table tbody tr:last-child th,
  .priv-table tbody tr:last-child td {
    border-bottom: none;
  }
  .priv-table tbody tr:hover th,
  .priv-table tbody tr:hover td {
    background: var(--surface-soft);
  }

  @media (max-width: 900px) {
    .privacy-shell {
      grid-template-columns: minmax(0, var(--prose-max));
      justify-content: center;
      row-gap: var(--s-4);
    }
    .privacy-toc-side,
    .priv-block {
      grid-column: 1;
      grid-row: auto;
    }
    .privacy-toc-side {
      position: static;
      max-width: none;
      max-height: none;
      overflow: visible;
      padding: var(--s-4);
      background: var(--surface-soft);
      border-radius: var(--radius-md);
    }
    .privacy-toc-side .toc-list { border-left: none; }
    .privacy-toc-side .toc-list a {
      padding: 6px 0;
      margin-left: 0;
      border-left: none;
    }
    .privacy-toc-side .toc-list a.is-active { border-left: none; }
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-priv-toc]'));
  const targets = links
    .map((link) => {
      const id = link.getAttribute('href')?.slice(1) ?? '';
      const el = id ? document.getElementById(id) : null;
      return el ? { link, el } : null;
    })
    .filter((x): x is { link: HTMLAnchorElement; el: HTMLElement } => x !== null);

  if (targets.length) {
    const setActive = (active: HTMLAnchorElement | null) => {
      for (const { link } of targets) {
        link.classList.toggle('is-active', link === active);
      }
    };
    const update = () => {
      const offset = 120;
      let current: HTMLAnchorElement | null = null;
      for (const { link, el } of targets) {
        if (el.getBoundingClientRect().top - offset <= 0) current = link;
        else break;
      }
      if (!current && window.scrollY < 200) current = targets[0].link;
      setActive(current);
    };
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>
