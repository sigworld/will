---
import type { Locale } from '../i18n';
import { getCopy } from '../i18n';
import Keycaps from './Keycaps.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getCopy(locale);
---

<section class="section" id="speak">
  <div class="container">
    <div class="section-header">
      <h2>{t.speak.title}</h2>
      <p class="lede">{t.speak.lede}</p>
    </div>

    <div class="demo-container demo-speak" data-demo-speak data-locale={locale}>
      <div class="app-frame">
        <div class="app-titlebar">
          <span class="app-dot app-dot-r"></span>
          <span class="app-dot app-dot-y"></span>
          <span class="app-dot app-dot-g"></span>
          <span class="app-title">
            {t.speak.chromeApp} <span class="app-title-channel">— {t.speak.chromeChannel}</span>
          </span>
        </div>
        <div class="app-body">
          <div class="composer" data-composer>
            <div class="composer-prompt" data-composer-prompt>{t.speak.placeholder}</div>
            <div class="composer-text" data-composer-text></div>
            <div class="composer-cursor" data-composer-cursor aria-hidden="true"></div>
          </div>

          <div class="dock">
            <button class="mic-button" data-mic type="button" aria-label={t.speak.holdToSpeak}>
              <span class="mic-icon" aria-hidden="true"></span>
              <span class="mic-waves" data-waves aria-hidden="true">
                <span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span>
              </span>
            </button>
            <div class="dock-meta">
              <div class="dock-status" data-status>{t.speak.holdToSpeak}</div>
              <div class="dock-key">
                <span class="key-glyph" data-key-opt>⌥</span>
                <span class="dock-key-label">Option</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="gesture-row">
        <button class="replay-pill" data-replay type="button">↻ {t.speak.replay}</button>
        <button class="replay-pill" data-next type="button">→ {t.speak.next}</button>
      </div>

      <div class="demo-shortcut" aria-hidden="true" data-shortcut-hint>
        <Keycaps shortcut={t.speak.shortcutHint.key} />
        <span class="demo-shortcut-label">{t.speak.shortcutHint.label}</span>
      </div>
    </div>

    <p class="after">{t.speak.after}</p>
  </div>
</section>

<script
  is:inline
  type="application/json"
  data-speak-samples
  set:html={JSON.stringify(t.speak.samples)}
/>
<script
  is:inline
  type="application/json"
  data-speak-strings
  set:html={JSON.stringify({
    holdToSpeak: t.speak.holdToSpeak,
    releaseToFinish: t.speak.releaseToFinish,
    refining: t.speak.refining,
    placeholder: t.speak.placeholder,
  })}
/>

<style>
  .demo-speak { position: relative; }

  /* ─── Composer (looks like a real Slack/Mail input) ─── */
  .composer {
    position: relative;
    min-height: 140px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--s-4) var(--s-4);
    font-size: var(--text-body-l);
    line-height: 1.55;
    background: var(--bg-primary);
    transition: border-color var(--dur-fast) var(--ease-out-quad);
  }
  .composer.is-listening { border-color: var(--signal-blue); }

  .composer-prompt {
    color: var(--text-tertiary);
    pointer-events: none;
    transition: opacity var(--dur-fast) var(--ease-out-quad);
  }
  .composer.has-content .composer-prompt { opacity: 0; }

  .composer-text {
    position: absolute;
    inset: var(--s-4) var(--s-4);
    color: var(--text-primary);
    pointer-events: none;
  }
  .composer-text .live-preview { display: inline; }
  .composer-text .refined { color: var(--text-primary); }

  .composer-cursor {
    position: absolute;
    width: 2px;
    height: 22px;
    background: var(--signal-blue);
    left: var(--s-4);
    top: var(--s-4);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out-quad), transform var(--dur-fast) var(--ease-out-quad);
    animation: cursor-blink 1.1s steps(2, end) infinite;
  }
  .composer.has-cursor .composer-cursor { opacity: 1; }
  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  /* ─── Dock with mic button ─── */
  .dock {
    margin-top: var(--s-4);
    display: flex;
    align-items: center;
    gap: var(--s-4);
  }
  .mic-button {
    position: relative;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--bg-primary);
    border: 1px solid var(--border-strong);
    cursor: pointer;
    flex-shrink: 0;
    transition:
      background var(--dur-fast) var(--ease-out-quad),
      border-color var(--dur-fast) var(--ease-out-quad),
      transform var(--dur-fast) var(--ease-out-quad);
  }
  .mic-button:hover { border-color: var(--text-primary); }
  .mic-button.is-active {
    background: var(--signal-blue);
    border-color: var(--signal-blue);
    transform: scale(0.96);
  }
  .mic-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 12px;
    height: 18px;
    border-radius: 6px;
    background: var(--text-secondary);
    transition: background var(--dur-fast) var(--ease-out-quad);
  }
  .mic-icon::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -8px;
    transform: translateX(-50%);
    width: 8px;
    height: 4px;
    border: 2px solid var(--text-secondary);
    border-top: none;
    border-radius: 0 0 6px 6px;
    transition: border-color var(--dur-fast) var(--ease-out-quad);
  }
  .mic-button.is-active .mic-icon { background: var(--clean-white); }
  .mic-button.is-active .mic-icon::after { border-color: var(--clean-white); }

  .mic-waves {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 30px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out-quad);
  }
  .mic-button.is-active .mic-waves { opacity: 1; }
  .mic-button.is-active .mic-icon { opacity: 0; }
  .mic-waves span {
    display: block;
    width: 2px;
    background: var(--clean-white);
    border-radius: 1px;
    animation: mic-wave 0.7s ease-in-out infinite;
  }
  .mic-waves span:nth-child(1) { height: 8px;  animation-delay: 0.00s; }
  .mic-waves span:nth-child(2) { height: 18px; animation-delay: 0.07s; }
  .mic-waves span:nth-child(3) { height: 12px; animation-delay: 0.14s; }
  .mic-waves span:nth-child(4) { height: 22px; animation-delay: 0.21s; }
  .mic-waves span:nth-child(5) { height: 14px; animation-delay: 0.28s; }
  .mic-waves span:nth-child(6) { height: 20px; animation-delay: 0.35s; }
  .mic-waves span:nth-child(7) { height: 10px; animation-delay: 0.42s; }
  .mic-waves span:nth-child(8) { height: 6px;  animation-delay: 0.49s; }
  @keyframes mic-wave {
    0%, 100% { transform: scaleY(0.5); opacity: 0.7; }
    50% { transform: scaleY(1.0); opacity: 1; }
  }

  .dock-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .dock-status {
    font-size: var(--text-body);
    font-weight: var(--weight-ui);
    color: var(--text-primary);
    transition: color var(--dur-fast) var(--ease-out-quad);
  }
  .dock-status.is-listening { color: var(--signal-blue); }
  .dock-key {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-body-s);
    color: var(--text-tertiary);
  }

  .after {
    margin-top: var(--s-5);
    text-align: center;
    color: var(--text-secondary);
    font-size: var(--text-body-s);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .composer-cursor,
    .mic-waves span { animation: none; }
  }
</style>

<script>
  type Sample = { raw: string; refined: string };
  type Strings = {
    holdToSpeak: string;
    releaseToFinish: string;
    refining: string;
    placeholder: string;
  };

  const root = document.querySelector<HTMLElement>('[data-demo-speak]');
  if (root) {
    const samples: Sample[] = JSON.parse(
      document.querySelector('[data-speak-samples]')?.textContent || '[]'
    );
    const strings: Strings = JSON.parse(
      document.querySelector('[data-speak-strings]')?.textContent || '{}'
    );

    const composer = root.querySelector<HTMLElement>('[data-composer]')!;
    const prompt = root.querySelector<HTMLElement>('[data-composer-prompt]')!;
    const textEl = root.querySelector<HTMLElement>('[data-composer-text]')!;
    const cursor = root.querySelector<HTMLElement>('[data-composer-cursor]')!;
    const mic = root.querySelector<HTMLButtonElement>('[data-mic]')!;
    const optKey = root.querySelector<HTMLElement>('[data-key-opt]')!;
    const status = root.querySelector<HTMLElement>('[data-status]')!;
    const replayBtn = root.querySelector<HTMLButtonElement>('[data-replay]')!;
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-next]')!;
    const shortcutChips = Array.from(
      root.querySelectorAll<HTMLElement>('[data-shortcut-hint] [data-kbd-token]')
    );

    let timers: number[] = [];
    let index = 0;
    let inflight = false;
    let cycleTimer: number | undefined;
    let isVisible = false;
    const CYCLE_DELAY = 2500;

    function clear() {
      timers.forEach((id) => window.clearTimeout(id));
      timers = [];
      if (cycleTimer !== undefined) {
        window.clearTimeout(cycleTimer);
        cycleTimer = undefined;
      }
    }
    function after(ms: number, fn: () => void) {
      const id = window.setTimeout(fn, ms);
      timers.push(id);
    }
    function scheduleNextCycle() {
      if (cycleTimer !== undefined) {
        window.clearTimeout(cycleTimer);
        cycleTimer = undefined;
      }
      if (!isVisible) return;
      cycleTimer = window.setTimeout(() => {
        cycleTimer = undefined;
        playNext();
      }, CYCLE_DELAY);
    }

    function resetUI() {
      composer.classList.remove('is-listening', 'has-content', 'has-cursor');
      mic.classList.remove('is-active');
      optKey.classList.remove('is-pressed');
      status.classList.remove('is-listening');
      status.textContent = strings.holdToSpeak;
      textEl.textContent = '';
      prompt.textContent = strings.placeholder;
      shortcutChips.forEach((c) => c.classList.remove('is-pressed'));
    }

    function setLivePreview(text: string) {
      composer.classList.add('has-content');
      textEl.replaceChildren();
      const span = document.createElement('span');
      span.className = 'live-preview';
      span.textContent = text;
      textEl.appendChild(span);
    }

    function setRefined(text: string) {
      composer.classList.add('has-content', 'has-cursor');
      textEl.replaceChildren();
      const span = document.createElement('span');
      span.className = 'refined fog-reveal';
      span.textContent = text;
      textEl.appendChild(span);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => span.classList.add('is-revealed'));
      });
      // Position the cursor at the end of the refined text.
      requestAnimationFrame(() => {
        const rect = span.getBoundingClientRect();
        const parentRect = composer.getBoundingClientRect();
        const left = rect.right - parentRect.left + 2;
        const top = rect.top - parentRect.top;
        cursor.style.transform = `translate(${left - 24}px, ${top - 24}px)`;
      });
    }

    function play(sample: Sample) {
      if (inflight) return;
      inflight = true;
      clear();
      resetUI();

      // Press Option (double-tap). The shortcut hint shows two ⌥ chips —
      // flash them in sequence to read as a real double-tap.
      after(60,  () => shortcutChips[0]?.classList.add('is-pressed'));
      after(160, () => shortcutChips[0]?.classList.remove('is-pressed'));
      after(180, () => {
        optKey.classList.add('is-pressed');
        mic.classList.add('is-active');
        composer.classList.add('is-listening');
        status.classList.add('is-listening');
        status.textContent = strings.releaseToFinish;
        shortcutChips[1]?.classList.add('is-pressed');
      });
      after(360, () => shortcutChips[1]?.classList.remove('is-pressed'));

      // Type the live SFSpeech-style preview word by word.
      const raw = sample.raw;
      const words = raw.split(/(\s+)/);
      let typed = '';
      let typeStart = 480;
      const wordDelay = 130;
      words.forEach((word, i) => {
        after(typeStart + i * wordDelay, () => {
          typed += word;
          setLivePreview(typed);
        });
      });
      const typingEnd = typeStart + words.length * wordDelay;

      // Release: option pops back, mic stops, status switches to refining.
      after(typingEnd + 250, () => {
        optKey.classList.remove('is-pressed');
        mic.classList.remove('is-active');
        composer.classList.remove('is-listening');
        status.classList.remove('is-listening');
        status.textContent = strings.refining;
      });

      // Reveal refined text via fog.
      after(typingEnd + 900, () => {
        setRefined(sample.refined);
        status.textContent = strings.holdToSpeak;
      });

      after(typingEnd + 1600, () => {
        inflight = false;
        scheduleNextCycle();
      });
    }

    function playCurrent() { play(samples[index]); }
    function playNext() {
      index = (index + 1) % samples.length;
      play(samples[index]);
    }

    mic.addEventListener('click', playCurrent);
    replayBtn.addEventListener('click', playCurrent);
    nextBtn.addEventListener('click', playNext);

    // Auto-play when the section scrolls into view; pause the cycle when out of view.
    let firstView = true;
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        isVisible = e.isIntersecting;
        if (e.isIntersecting) {
          if (firstView) {
            firstView = false;
            after(400, playCurrent);
          } else if (!inflight && cycleTimer === undefined) {
            scheduleNextCycle();
          }
        } else if (cycleTimer !== undefined) {
          window.clearTimeout(cycleTimer);
          cycleTimer = undefined;
        }
      }
    }, { threshold: 0.4 });
    io.observe(root);
  }
</script>
